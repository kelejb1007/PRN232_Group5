@{
    Layout = null;
}
@model Models.UserAccount.AuthDTO.ResetPasswordRequestDTO

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đặt lại mật khẩu | Intelligence Book</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-color: rgba(25, 36, 50, 1);
            --accent-color: #c5a059;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8f9fa;
            margin: 0;
        }

        .login-container {
            min-height: 100vh;
            display: flex;
        }

        .login-image {
            background: linear-gradient(rgba(25, 36, 50, 0.8), rgba(25, 36, 50, 0.8)), url('https://images.unsplash.com/photo-1456513080510-7bf3a84b82f8?ixlib=rb-1.2.1&auto=format&fit=crop&w=1350&q=80');
            background-size: cover;
            background-position: center;
            width: 50%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            color: white;
            padding: 40px;
        }

        .login-image h1 {
            font-family: 'Playfair Display', serif;
            font-size: 3.5rem;
            margin-bottom: 20px;
        }

        .login-form-section {
            width: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: white;
            padding: 60px;
        }

        .form-wrapper {
            max-width: 400px;
            width: 100%;
        }

        .brand-logo {
            color: var(--primary-color);
            font-family: 'Playfair Display', serif;
            font-size: 2rem;
            font-weight: bold;
            margin-bottom: 30px;
            text-decoration: none;
            display: block;
        }

        .btn-login {
            background-color: var(--primary-color);
            color: white;
            border: none;
            padding: 12px;
            border-radius: 5px;
            font-weight: 600;
            transition: 0.3s;
            width: 100%;
        }

        .btn-login:hover {
            background-color: var(--accent-color);
            color: white;
        }

        .form-control {
            padding: 12px;
            border-radius: 5px;
            border: 1px solid #ddd;
        }

        .form-control:focus {
            border-color: var(--accent-color);
            box-shadow: none;
        }

        @@media (max-width: 992px) {
            .login-image { display: none; }
            .login-form-section { width: 100%; }
        }
        .otp-container {
            display: flex;
            gap: 10px;
            justify-content: center;
            margin-bottom: 1.5rem;
        }

        .otp-input {
            width: 45px;
            height: 55px;
            text-align: center;
            font-size: 1.5rem;
            font-weight: bold;
            border: 2px solid #ddd;
            border-radius: 8px;
            background: #fff;
            transition: all 0.3s ease;
        }

        .otp-input:focus {
            border-color: var(--accent-color);
            box-shadow: 0 0 8px rgba(197, 160, 89, 0.2);
            outline: none;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-image">
            <h1>Stay Connected</h1>
            <p class="fs-5 text-center fw-light">"A room without books is like a body without a soul."</p>
            <div class="mt-4 border-top pt-3 w-50 text-center" style="border-color: rgba(255,255,255,0.3) !important;">
                <small>EST. 2024</small>
            </div>
        </div>

        <div class="login-form-section">
            <div class="form-wrapper">
                <a href="/" class="brand-logo text-center">BookStore.</a>
                <h2 class="fw-bold mb-2">Đặt lại mật khẩu</h2>
                <p class="text-muted mb-4">Vui lòng nhập mật khẩu mới của bạn bên dưới.</p>

                <div id="otpTimer" class="mb-3 text-center">
                    <span class="badge bg-light text-dark border p-2">
                        <i class="bi bi-clock me-1"></i> Mã hết hạn sau: <span id="timerValue" class="fw-bold text-danger">02:00</span>
                    </span>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger border-0 small">@ViewBag.Error</div>
                }
                
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <form asp-action="ResetPassword" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Email" />
                    
                    <div class="mb-3">
                        <label class="form-label small fw-bold">MÃ OTP 6 CHỮ SỐ</label>
                        <input type="hidden" asp-for="Token" id="fullToken" />
                        <div class="otp-container">
                            <input type="text" class="otp-input" maxlength="1" pattern="\d*" inputmode="numeric">
                            <input type="text" class="otp-input" maxlength="1" pattern="\d*" inputmode="numeric">
                            <input type="text" class="otp-input" maxlength="1" pattern="\d*" inputmode="numeric">
                            <input type="text" class="otp-input" maxlength="1" pattern="\d*" inputmode="numeric">
                            <input type="text" class="otp-input" maxlength="1" pattern="\d*" inputmode="numeric">
                            <input type="text" class="otp-input" maxlength="1" pattern="\d*" inputmode="numeric">
                        </div>
                        <span asp-validation-for="Token" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold">MẬT KHẨU MỚI</label>
                        <div class="input-group">
                            <input asp-for="NewPassword" type="password" id="passwordInput" class="form-control" placeholder="" required style="border-right: none;" minlength="6">
                            <button class="btn btn-outline-secondary bg-white text-muted" type="button" id="togglePassword" style="border-left: none; border-color: #ddd;">
                                <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                  <path d="M10.5 8a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0z"/>
                                  <path d="M0 8s3-5.5 8-5.5S16 8 16 8s-3 5.5-8 5.5S0 8 0 8zm8 3.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7z"/>
                                </svg>
                                <svg id="eyeSlashIcon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" style="display: none;">
                                  <path d="m10.79 12.912-1.614-1.615a3.5 3.5 0 0 1-4.474-4.474l-2.06-2.06C.938 6.278 0 8 0 8s3 5.5 8 5.5a7.029 7.029 0 0 0 2.79-.588zM5.21 3.088A7.028 7.028 0 0 1 8 2.5c5 0 8 5.5 8 5.5s-.939 1.721-2.641 3.238l-2.062-2.062a3.5 3.5 0 0 0-4.474-4.474L5.21 3.089z"/>
                                  <path d="M5.525 7.646a2.5 2.5 0 0 0 2.829 2.829l-2.83-2.829zm4.95.708-2.829-2.83a2.5 2.5 0 0 1 2.829 2.829zm3.171 6-12-12 .708-.708 12 12-.708.708z"/>
                                </svg>
                            </button>
                        </div>
                        <span asp-validation-for="NewPassword" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <button type="submit" class="btn btn-login mb-2">ĐẶT LẠI MẬT KHẨU</button>

                    <div class="mt-2 text-center">
                        <small class="text-muted">Không nhận được mã? </small>
                        <a href="javascript:void(0)" id="resendBtn" onclick="resendOtp('@Model.Email', 'forgot')" class="small fw-bold text-decoration-none" style="color: var(--accent-color);">Gửi lại mã</a>
                        <div id="resendTimer" class="small text-muted mt-1" style="display: none;">Vui lòng đợi <span id="resendValue">30</span> giây để gửi lại</div>
                    </div>

                    <div class="text-center mt-4">
                        <p class="small text-muted">
                            Đã nhớ mật khẩu?
                            <a asp-action="Login" class="fw-bold text-decoration-none" style="color: var(--accent-color);">Quay lại Đăng nhập</a>
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        function resendOtp(email, type) {
            const btn = document.getElementById('resendBtn');
            const resendTimerDiv = document.getElementById('resendTimer');
            const resendValueSpan = document.getElementById('resendValue');
            
            btn.style.pointerEvents = "none";
            btn.style.opacity = "0.5";

            fetch(`/Auth/ResendOtp?email=${encodeURIComponent(email)}&type=${encodeURIComponent(type)}`, {
                method: 'POST',
                headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value }
            })
            .then(response => response.json())
            .then(data => {
                alert(data.message);
                if (data.success) {
                    // Start 30s cooldown
                    let timeLeft = 30;
                    resendTimerDiv.style.display = "block";
                    btn.style.display = "none";
                    
                    const cooldownInterval = setInterval(() => {
                        timeLeft--;
                        resendValueSpan.innerText = timeLeft;
                        if (timeLeft <= 0) {
                            clearInterval(cooldownInterval);
                            resendTimerDiv.style.display = "none";
                            btn.style.display = "inline";
                            btn.style.pointerEvents = "auto";
                            btn.style.opacity = "1";
                        }
                    }, 1000);

                    // Reset 2m timer
                    startOtpTimer(120);
                } else {
                    btn.style.pointerEvents = "auto";
                    btn.style.opacity = "1";
                }
            })
            .catch(() => {
                alert("Có lỗi xảy ra khi gửi lại mã.");
                btn.style.pointerEvents = "auto";
                btn.style.opacity = "1";
            });
        }

        let mainTimerInterval;
        function startOtpTimer(durationSeconds) {
            clearInterval(mainTimerInterval);
            let timer = durationSeconds;
            const display = document.getElementById('timerValue');
            const submitBtn = document.querySelector('form button[type="submit"]');
            
            if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.style.opacity = "1";
            }

            mainTimerInterval = setInterval(() => {
                let minutes = Math.floor(timer / 60);
                let seconds = timer % 60;

                display.innerText = (minutes < 10 ? "0" + minutes : minutes) + ":" + (seconds < 10 ? "0" + seconds : seconds);

                if (--timer < 0) {
                    clearInterval(mainTimerInterval);
                    display.innerText = "Đã hết hạn";
                    if (submitBtn) {
                        submitBtn.disabled = true;
                        submitBtn.style.opacity = "0.5";
                    }
                }
            }, 1000);
        }

        document.addEventListener('DOMContentLoaded', function() {
            // Start the 2-minute timer
            startOtpTimer(120);

            const inputs = document.querySelectorAll('.otp-input');
            const hiddenInput = document.getElementById('fullToken');
            const form = document.querySelector('form');

            inputs.forEach((input, index) => {
                input.addEventListener('input', (e) => {
                    if (e.target.value.length === 1 && index < inputs.length - 1) {
                        inputs[index + 1].focus();
                    }
                    updateHiddenInput();
                });

                input.addEventListener('keydown', (e) => {
                    if (e.key === 'Backspace' && !e.target.value && index > 0) {
                        inputs[index - 1].focus();
                    }
                });

                input.addEventListener('paste', (e) => {
                    e.preventDefault();
                    const pasteData = e.clipboardData.getData('text').slice(0, 6);
                    if (/^\d+$/.test(pasteData)) {
                        pasteData.split('').forEach((char, i) => {
                            if (inputs[i]) inputs[i].value = char;
                        });
                        inputs[Math.min(pasteData.length, inputs.length - 1)].focus();
                        updateHiddenInput();
                    }
                });
            });

            function updateHiddenInput() {
                let token = '';
                inputs.forEach(input => token += input.value);
                hiddenInput.value = token;
            }

            form.addEventListener('submit', (e) => {
                updateHiddenInput();
                if (hiddenInput.value.length !== 6) {
                    e.preventDefault();
                    alert('Vui lòng nhập đầy đủ mã OTP 6 chữ số.');
                }
            });

            document.getElementById('togglePassword').addEventListener('click', function () {
                const passwordInput = document.getElementById('passwordInput');
                const eyeIcon = document.getElementById('eyeIcon');
                const eyeSlashIcon = document.getElementById('eyeSlashIcon');
                if (passwordInput.type === 'password') {
                    passwordInput.type = 'text';
                    eyeIcon.style.display = 'none';
                    eyeSlashIcon.style.display = 'block';
                } else {
                    passwordInput.type = 'password';
                    eyeIcon.style.display = 'block';
                    eyeSlashIcon.style.display = 'none';
                }
            });
        });
    </script>
</body>
</html>

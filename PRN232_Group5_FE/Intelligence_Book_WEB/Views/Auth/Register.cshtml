@{
    Layout = null;
}
@model Models.UserAccount.AuthDTO.RegisterRequestDTO

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Join Us | Intelligence Book Store</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-color: #1a2a3a;
            --accent-color: #c5a059;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f4f1ea;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .register-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.1);
            width: 100%;
            max-width: 900px;
            display: flex;
            overflow: hidden;
        }

        .register-info {
            background: var(--primary-color);
            color: white;
            width: 40%;
            padding: 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .register-form {
            width: 60%;
            padding: 50px;
        }

        .btn-register {
            background: var(--primary-color);
            color: white;
            border: none;
            padding: 12px;
            width: 100%;
            border-radius: 5px;
            font-weight: 600;
            margin-top: 10px;
        }

            .btn-register:hover {
                background: var(--accent-color);
                color: white;
            }

        .form-label {
            font-size: 0.75rem;
            font-weight: 700;
            color: #666;
            letter-spacing: 0.5px;
        }

        @@media (max-width: 768px) {
            .register-card {
                flex-direction: column;
            }

            .register-info, .register-form {
                width: 100%;
                padding: 30px;
            }
        }
    </style>
</head>
<body>

    <div class="register-card">
        <div class="register-info text-center">
            <h2 style="font-family: 'Playfair Display';">Join the Club</h2>
            <p class="fw-light opacity-75 mt-3">Become a member of Intelligence Book and get exclusive access to rare collections and literary events.</p>
            <div class="mt-4">
                <img src="https://cdn-icons-png.flaticon.com/512/3429/3429149.png" width="120" style="filter: invert(1); opacity: 0.8;" alt="Book Icon">
            </div>
        </div>

        <div class="register-form">
            <h3 class="fw-bold mb-4">Create Account</h3>
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger py-2 small">@ViewBag.Error</div>
            }
            <form asp-action="Register" method="post">
                @Html.AntiForgeryToken()
                <div class="row">
                    <div class="col-md-12 mb-3">
                        <label class="form-label">FULL NAME</label>
                        <input asp-for="FullName" class="form-control" placeholder="John Doe" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">USERNAME</label>
                        <input asp-for="Username" class="form-control" placeholder="johndoe123" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">EMAIL</label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="john@example.com" required />
                    </div>
                    <div class="col-md-12 mb-4">
                        <label class="form-label">PASSWORD</label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="At least 8 characters" required />
                    </div>
                </div>

                <button type="submit" class="btn btn-register">REGISTER NOW</button>

                <p class="text-center mt-4 small text-muted">
                    Already a member? <a asp-action="Login" class="text-decoration-none fw-bold" style="color: var(--accent-color);">Sign In</a>
                </p>
            </form>
        </div>
    </div>

</body>
</html>
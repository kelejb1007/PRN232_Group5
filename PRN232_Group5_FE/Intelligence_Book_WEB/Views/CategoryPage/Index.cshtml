@* @page *@
@model List<CategoryViewModel>

@{
    ViewData["Title"] = "Category Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link rel="stylesheet" href="~/css/CategoryIndex.css" asp-append-version="true" />

<div class="category-page">
    <div class="edit-category-header">
        <h1>Category Management</h1>
    </div>



    <div class="p-3">
        <p>
            <a asp-controller="CategoryPage" asp-action="Create" class="btn btn-primary" style="background-color: #F79356; border: none;">
                <i class="bi bi-plus-circle"></i> Create New Category
            </a>
        </p>

        <table class="table table-hover mt-3">
            <thead style="background-color: #ffe9d0;">
                <tr>
                    <th>Category ID</th>
                    <th>Name</th>
                    <th>Description</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var category in Model)
                    {
                        <tr>
                            <td>@category.CategoryId</td>
                            <td>@category.CategoryName</td>
                            <td>@category.Description</td>
                            <td class="text-center">
                                <a asp-controller="CategoryPage" asp-action="Edit" asp-route-id="@category.CategoryId" class="btn btn-sm btn-outline-warning">
                                    <i class="bi bi-pencil"></i> Edit
                                </a> |
                                <form asp-controller="CategoryPage" asp-action="Delete" asp-route-id="@category.CategoryId" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure?');">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center">No categories found</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

    @* ===== PAGINATION (Controller không trả TotalPages nên bỏ) ===== *@
    @*
    @if (Model.TotalPages > 1)
    {
        <div class="pagination-container">
            ...
        </div>
    }
    *@

</div>
@model List<CategoryViewModel>

@{
    ViewData["Title"] = "Quản lý Danh mục";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link rel="stylesheet" href="~/css/CategoryIndex.css" asp-append-version="true" />

<div class="container-fluid p-4">
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="edit-category-header">
            <h2 class="fw-bold mb-0">Quản lý Danh mục</h2>
        </div>

        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                     <a asp-controller="CategoryPage"
                        asp-action="Create"
                        class="btn btn-warning fw-bold px-4 py-2 rounded-3 shadow-sm text-white">
                         <i class="bi bi-plus-circle me-2"></i> Thêm Danh mục
                     </a>
                </div>
                
                @* Placeholder for search if needed later *@
                <div class="text-muted small">
                    Hiển thị tổng cộng @(Model?.Count ?? 0) danh mục
                </div>
            </div>

            <div class="table-container">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted small">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Tên Danh mục</th>
                            <th>Mô tả</th>
                            <th class="text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var category in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-muted">#@category.CategoryId</td>
                                    <td><span class="fw-bold text-dark">@category.CategoryName</span></td>
                                    <td><span class="text-muted small">@category.Description</span></td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group">
                                            <a asp-controller="CategoryPage"
                                               asp-action="Edit"
                                               asp-route-id="@category.CategoryId"
                                               class="btn btn-sm btn-outline-warning rounded-start-3 px-3">
                                                Sửa
                                            </a>
                                            <form asp-controller="CategoryPage"
                                                  asp-action="Delete"
                                                  asp-route-id="@category.CategoryId"
                                                  method="post"
                                                  class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit"
                                                        class="btn btn-sm btn-outline-danger rounded-end-3 px-3"
                                                        onclick="return confirm('Bạn có chắc chắn muốn xóa danh mục này?');">
                                                    Xóa
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-3 opacity-25"></i>
                                    Không có danh mục nào được tìm thấy.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Optional search logic can go here
    </script>
}
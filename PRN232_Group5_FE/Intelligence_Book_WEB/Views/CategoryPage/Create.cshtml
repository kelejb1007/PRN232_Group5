@model Intelligence_Book_WEB.Models.CategoryViewModel

@{
    ViewData["Title"] = "Thêm mới Danh mục";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="category-page">
    <div class="d-flex justify-content-between align-items-center mb-4 rounded shadow-sm" style="background-color: #111827; border-left: 5px solid #c5a059; padding: 20px;">
        <h2 class="text-white m-0 fw-bold"><i class="bi bi-plus-square me-2" style="color: #c5a059;"></i> Thêm Danh mục mới</h2>
    </div>

    <div class="container bg-white p-4 shadow-sm rounded" style="max-width: 800px; margin: 0 auto;">
        <form asp-controller="CategoryPage" asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

            <div class="mb-4">
                <label asp-for="CategoryName" class="form-label fw-bold">Tên danh mục <span class="text-danger">*</span></label>
                <input asp-for="CategoryName" class="form-control" placeholder="Nhập tên danh mục (vd: Tiểu thuyết khoa học viễn tưởng)" />
                <span asp-validation-for="CategoryName" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Description" class="form-label fw-bold">Mô tả danh mục</label>
                <textarea asp-for="Description" class="form-control" rows="5" placeholder="Miêu tả nội dung, đặc điểm các sách trong danh mục này..."></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="mt-5 pt-3 border-top text-end">
                <a asp-controller="CategoryPage" asp-action="Index" class="btn btn-outline-secondary px-4 me-2 hover-lift">
                    <i class="bi bi-x-circle me-1"></i> Hủy bỏ
                </a>
                <button type="submit" class="btn text-white px-5 fw-bold hover-lift" style="background-color: #c5a059;">
                    <i class="bi bi-save me-1"></i> Lưu Danh mục
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

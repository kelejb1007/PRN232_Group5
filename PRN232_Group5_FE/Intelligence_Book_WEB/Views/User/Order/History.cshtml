@model IEnumerable<Intelligence_Book_WEB.Models.Order.OrderHistoryDTO>
@{
    ViewData["Title"] = "Lịch sử đơn hàng";
}

<div class="container mt-5 mb-5">
    <div class="row">
        <!-- Sidebar Navigation -->
        <div class="col-md-3 mb-4">
            <partial name="_ProfileSidebar" />
        </div>

        <div class="col-md-9">
            <div class="mb-4">
                <h2 class="fw-bold"><i class="bi bi-bag-check me-2"></i>Lịch sử đơn hàng</h2>
                <p class="text-muted">Theo dõi và quản lý các đơn hàng trước đây của bạn.</p>
            </div>

            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    @if (Model == null || !Model.Any())
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-cart-x text-muted" style="font-size: 3rem;"></i>
                            <p class="text-muted mt-2">Bạn chưa có đơn hàng nào.</p>
                            <a href="/" class="btn btn-primary mt-3 px-4">Bắt đầu mua sắm</a>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th class="small py-3">MÃ ĐƠN HÀNG</th>
                                        <th class="small py-3">NGÀY ĐẶT</th>
                                        <th class="small py-3">TỔNG TIỀN</th>
                                        <th class="small py-3">TRẠNG THÁI</th>
                                        <th class="small py-3 text-end">HÀNH ĐỘNG</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model)
                                    {
                                        <tr>
                                            <td class="small fw-bold">#@order.OrderId</td>
                                            <td class="small text-muted">@order.OrderDate.ToString("dd MMM yyyy HH:mm")</td>
                                            <td class="small fw-bold text-primary">@order.TotalAmount.ToString("C")</td>
                                            <td>
                                                @{
                                                    var badgeClass = order.Status switch
                                                    {
                                                        "Pending" => "bg-warning-subtle text-warning border-warning-subtle",
                                                        "Processing" => "bg-info-subtle text-info border-info-subtle",
                                                        "Shipped" => "bg-primary-subtle text-primary border-primary-subtle",
                                                        "Delivered" => "bg-success-subtle text-success border-success-subtle",
                                                        "Cancelled" => "bg-danger-subtle text-danger border-danger-subtle",
                                                        _ => "bg-secondary-subtle text-secondary border-secondary-subtle"
                                                    };
                                                    var statusVn = order.Status switch
                                                    {
                                                        "Pending" => "Chờ xử lý",
                                                        "Processing" => "Đang xử lý",
                                                        "Shipped" => "Đang giao",
                                                        "Delivered" => "Đã giao",
                                                        "Cancelled" => "Đã hủy",
                                                        _ => order.Status
                                                    };
                                                }
                                                <span class="badge border px-2 py-1 @badgeClass">@statusVn</span>
                                            </td>
                                            <td class="text-end">
                                                <a asp-action="Details" asp-route-id="@order.OrderId" class="btn btn-outline-primary btn-sm px-3">Xem chi tiết</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}

@model Intelligence_Book_WEB.Models.Order.OrderHistoryDTO
@{
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.OrderId;
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <a asp-action="Profile" asp-route-tab="orders" class="btn btn-link text-decoration-none p-0 text-muted">
                    <i class="bi bi-arrow-left"></i> Quay lại lịch sử
                </a>
                <h3 class="fw-bold mb-0">Chi tiết đơn hàng #@Model.OrderId</h3>
            </div>

            <div class="row">
                <!-- Order summary -->
                <div class="col-lg-8 mb-4">
                    <div class="card shadow-sm border-0 rounded-4 h-100">
                        <div class="card-header bg-white border-bottom-0 pt-4 px-4">
                            <h5 class="fw-bold mb-0">Sản phẩm trong đơn hàng</h5>
                        </div>
                        <div class="card-body p-4">
                            <div class="table-responsive">
                                <table class="table align-middle">
                                    <thead>
                                        <tr class="text-muted small">
                                            <th>SẢN PHẨM</th>
                                            <th class="text-center">SỐ LƯỢNG</th>
                                            <th class="text-end">ĐƠN GIÁ</th>
                                            <th class="text-end">THÀNH TIỀN</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.OrderItems)
                                        {
                                            <tr>
                                                <td>
                                                    <div class="d-flex align-items-center">
                                                        @if (!string.IsNullOrEmpty(item.BookImage))
                                                        {
                                                            <img src="@item.BookImage" class="rounded me-3" style="width: 50px; height: 70px; object-fit: cover;" alt="@item.BookTitle" />
                                                        }
                                                        else
                                                        {
                                                            <div class="bg-light rounded me-3 d-flex align-items-center justify-content-center border" style="width: 50px; height: 70px;">
                                                                <i class="bi bi-book text-muted"></i>
                                                            </div>
                                                        }
                                                        <span class="fw-bold small">@item.BookTitle</span>
                                                    </div>
                                                </td>
                                                <td class="text-center small">@item.Quantity</td>
                                                <td class="text-end small">@item.UnitPrice.ToString("C")</td>
                                                <td class="text-end fw-bold small">@((item.Quantity * item.UnitPrice).ToString("C"))</td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot>
                                        <tr>
                                            <td colspan="3" class="text-end fw-bold pt-4 border-0">TỔNG CỘNG:</td>
                                            <td class="text-end fw-bold pt-4 border-0 fs-5 text-primary">@Model.TotalAmount.ToString("C")</td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Order stats -->
                <div class="col-lg-4">
                    <div class="card shadow-sm border-0 rounded-4 mb-4">
                        <div class="card-body p-4 text-center">
                            <p class="text-muted small mb-1">TRẠNG THÁI ĐƠN HÀNG</p>
                            @{
                                var badgeClass = Model.Status switch {
                                    "Pending" => "bg-warning",
                                    "Processing" => "bg-info",
                                    "Shipped" => "bg-primary",
                                    "Delivered" => "bg-success",
                                    "Cancelled" => "bg-danger",
                                    _ => "bg-secondary"
                                };
                                var statusVn = Model.Status switch
                                {
                                    "Pending" => "Chờ xử lý",
                                    "Processing" => "Đang xử lý",
                                    "Shipped" => "Đang giao",
                                    "Delivered" => "Đã giao",
                                    "Cancelled" => "Đã hủy",
                                    _ => Model.Status
                                };
                            }
                            <span class="badge @badgeClass fs-6 px-3 py-2 mb-3">@statusVn</span>
                            <hr />
                            <p class="text-muted small mb-1">NGÀY ĐẶT HÀNG</p>
                            <p class="fw-bold small">@Model.OrderDate.ToString("F")</p>
                        </div>
                    </div>

                    <div class="card shadow-sm border-0 rounded-4">
                        <div class="card-header bg-white border-bottom-0 pt-4 px-4">
                            <h6 class="fw-bold mb-0">Địa chỉ giao hàng</h6>
                        </div>
                        <div class="card-body p-4 pt-2">
                             <p class="small mb-0 text-muted">@Model.ShippingAddress</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}

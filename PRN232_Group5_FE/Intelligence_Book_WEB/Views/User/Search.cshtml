@model List<Intelligence_Book_WEB.Models.BookViewModel>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<style>
    body {
        background-color: #fff; /* Cam nhạt */
    }

    /* CSS cho icon trái tim trên hình ảnh */
    .book-card-container {
        position: relative;
    }

    .btn-addcart {
        background-color: #192432; /* màu bạn muốn */
        color: white; /* chữ màu trắng */
        border: none; /* bỏ viền mặc định */
    }

        .btn-addcart:hover {
            background-color: #1f2a38; /* màu hover nhạt hơn 1 chút */
            color: white;
        }
</style>

<div class="container mt-4">

    <h2 class="text-center mb-4" style="color: black ;">Book Store</h2>

    <form method="get" class="row mb-4">
        <div class="col-md-3">
            <input name="search"
                   class="form-control"
                   placeholder="Tìm kiếm sách..." />
        </div>
        <div class="col-md-3">
            <select name="categoryId" class="form-select">
                <option value="">All Categories</option>
                @foreach (var cate in ViewBag.Categories ?? new List<Intelligence_Book_WEB.Models.CategoryViewModel>())
                {
                    <option value="@cate.CategoryId"
                            selected="@(ViewBag.SelectedCategory != null && ViewBag.SelectedCategory == cate.CategoryId ? "selected" : null)">
                        @cate.CategoryName
                    </option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <input name="minPrice" type="number" class="form-control" placeholder="Min Price" />
        </div>

        <div class="col-md-2">
            <input name="maxPrice" type="number" class="form-control" placeholder="Max Price" />
        </div>

        <div class="col-md-2">
            <button class="btn btn-primary w-100">Tìm</button>
        </div>
    </form>

    <div class="row">
        @if (Model == null || !Model.Any())
        {
            <div class="col-12 text-center mt-5">
                <div class="alert alert-warning">
                    <i class="bi bi-search"></i> Không tìm thấy sách nào phù hợp với yêu cầu của bạn.
                </div>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col-md-3 mb-4" data-id="@item.BookId">
                    <div class="card shadow book-card-container">

                        <img src="@item.CoverImageUrl" class="card-img-top" height="250" />

                        <div class="card-body">
                            <h5>@item.Title</h5>
                            <p class="text-danger fw-bold">@item.Price.ToString("N0") đ</p>

                            <a asp-controller="Book"
                               asp-action="Details"
                               asp-route-id="@item.BookId"
                               class="btn btn-outline-primary w-100 mb-2">
                                Xem chi tiết
                            </a>

                            <a href="/Cart/Add/@item.BookId" class="btn btn-addcart w-100 mb-2">
                                Thêm vào giỏ hàng
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<script>
</script>
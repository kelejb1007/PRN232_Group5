@model IEnumerable<Intelligence_Book_WEB.Models.DeliveryAddress.DeliveryAddressDTO>
@{
    ViewData["Title"] = "Địa chỉ của tôi";
    ViewBag.ActiveTab = "addresses"; // Consistent Highlight
}

<div class="container mt-5 mb-5">
    <div class="row">
        <!-- Sidebar Navigation -->
        <div class="col-md-3 mb-4">
            <partial name="_ProfileSidebar" />
        </div>

        <!-- Main Content -->
        <div class="col-md-9">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-bottom-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                    <h4 class="fw-bold mb-0">Địa chỉ nhận hàng</h4>
                    <button class="btn btn-outline-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addAddressModal">
                        <i class="bi bi-plus-lg"></i> Thêm mới
                    </button>
                </div>
                <div class="card-body p-4">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success border-0 small">@TempData["SuccessMessage"]</div>
                    }
                    
                    @if (Model == null || !Model.Any())
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-geo-alt text-muted" style="font-size: 3rem;"></i>
                            <p class="text-muted mt-2">Không tìm thấy địa chỉ nhận hàng nào.</p>
                        </div>
                    }
                    else
                    {
                        <div class="row">
                            @foreach (var addr in Model)
                            {
                                <div class="col-md-6 mb-3">
                                    <div class="card h-100 border @(addr.IsDefault ? "border-primary" : "border-light shadow-sm")">
                                        <div class="card-body p-3">
                                            <div class="d-flex justify-content-between">
                                                <h6 class="fw-bold mb-1">@addr.ReceiverName</h6>
                                                @if (addr.IsDefault)
                                                {
                                                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle small px-2">Mặc định</span>
                                                }
                                            </div>
                                            <p class="small text-muted mb-1"><i class="bi bi-telephone"></i> @addr.PhoneNumber</p>
                                            <p class="small mb-3">@addr.AddressLine</p>
                                            <div class="d-flex gap-2">
                                                @if (!addr.IsDefault)
                                                {
                                                    <form asp-controller="Address" asp-action="SetDefault" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@addr.AddressId" />
                                                        <button type="submit" class="btn btn-link btn-sm p-0 text-decoration-none">Đặt làm mặc định</button>
                                                    </form>
                                                }
                                                <button class="btn btn-link btn-sm p-0 text-decoration-none text-danger" 
                                                        onclick="confirmDeleteAddress(@addr.AddressId)">Xóa</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Address Modal -->
<div class="modal fade" id="addAddressModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="fw-bold">Thêm địa chỉ nhận hàng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-controller="Address" asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">TÊN NGƯỜI NHẬN</label>
                        <input name="ReceiverName" class="form-control" placeholder="Nguyễn Văn A" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">SỐ ĐIỆN THOẠI</label>
                        <input name="PhoneNumber" class="form-control" placeholder="0123456789" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">ĐỊA CHỈ CHI TIẾT</label>
                        <textarea name="AddressLine" class="form-control" rows="3" placeholder="Số nhà, tên đường, phường/xã..." required></textarea>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0 p-4">
                    <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary px-4">Lưu địa chỉ</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirm Form (Invisible) -->
<form id="deleteAddressForm" asp-controller="Address" asp-action="Delete" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteAddressId" />
</form>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            window.confirmDeleteAddress = function(id) {
                if (confirm('Bạn có chắc chắn muốn xóa địa chỉ này?')) {
                    document.getElementById('deleteAddressId').value = id;
                    document.getElementById('deleteAddressForm').submit();
                }
            };
        });
    </script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}

@model Models.UserAccount.AuthDTO.UpdateProfileRequestDTO
@{
    ViewData["Title"] = "Hồ sơ của tôi";
    var profileInfo = ViewBag.ProfileInfo as Models.UserAccount.AuthDTO.UserProfileDTO;
    ViewBag.ActiveTab = "personal";
}

<div class="container mt-5 mb-5">
    <div class="row">
        <!-- Sidebar Navigation -->
        <div class="col-md-3 mb-4">
            <partial name="_ProfileSidebar" />
        </div>

        <!-- Main Content -->
        <div class="col-md-9">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-bottom-0 pt-4 px-4">
                    <h4 class="fw-bold mb-0">Thông tin cá nhân</h4>
                </div>
                <div class="card-body p-4">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success border-0 small">@TempData["SuccessMessage"]</div>
                    }
                    <form asp-controller="Profile" asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <div class="row mb-3">
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold">TÊN ĐĂNG NHẬP</label>
                                <input type="text" class="form-control bg-light" value="@profileInfo?.Username" readonly />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold">EMAIL</label>
                                <input type="email" class="form-control bg-light" value="@profileInfo?.Email" readonly />
                            </div>
                            <div class="col-md-12 mb-3">
                                <label class="form-label small fw-bold">HỌ VÀ TÊN</label>
                                <input asp-for="FullName" class="form-control" />
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold">SỐ ĐIỆN THOẠI</label>
                                <input asp-for="Phone" class="form-control" />
                                <span asp-validation-for="Phone" class="text-danger small"></span>
                            </div>
                            <div class="col-md-12 mb-4">
                                <label class="form-label small fw-bold">ĐỊA CHỈ</label>
                                <textarea asp-for="Address" class="form-control" rows="3"></textarea>
                                <span asp-validation-for="Address" class="text-danger small"></span>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary px-4">Cập nhật hồ sơ</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}

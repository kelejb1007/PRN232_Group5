@{
    ViewData["Title"] = "Home";
}

<style>
    :root {
        --primary: rgba(25, 36, 50, 1); /* Màu chủ đạo như bạn yêu cầu */
        --primary-dark: rgba(15, 25, 38, 1);
        --text-dark: #2c3e50;
    }

    body {
        background-color: #f8f9fa;
        font-family: 'Segoe UI', system-ui, sans-serif;
    }

    /* Carousel */
    #mainCarousel {
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

        #mainCarousel .carousel-item img {
            height: 460px;
            object-fit: cover;
        }

    /* Tiêu đề */
    .section-title {
        color: var(--text-dark);
        font-weight: 700;
        font-size: 1.75rem;
        position: relative;
        display: inline-block;
        margin-bottom: 1.5rem;
    }

        .section-title:after {
            content: '';
            position: absolute;
            bottom: -8px;
            left: 0;
            width: 70px;
            height: 4px;
            background: var(--primary);
            border-radius: 2px;
        }

    /* Danh mục */
    .category-card {
        background: white;
        border: 1px solid #eee;
        border-radius: 12px;
        padding: 1.8rem 1rem;
        font-size: 1.15rem;
        font-weight: 600;
        color: var(--text-dark);
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

        .category-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 25px rgba(25, 36, 50, 0.15);
            border-color: var(--primary);
            color: var(--primary);
        }

    /* Card sách */
    .book-card {
        border: none;
        border-radius: 12px;
        overflow: hidden;
        transition: all 0.4s ease;
        background: white;
        height: 100%;
    }

        .book-card:hover {
            transform: translateY(-12px);
            box-shadow: 0 20px 35px rgba(25, 36, 50, 0.12);
        }

        .book-card .card-img-top {
            height: 240px;
            object-fit: cover;
            transition: transform 0.4s ease;
        }

        .book-card:hover .card-img-top {
            transform: scale(1.06);
        }

        .book-card .card-body {
            padding: 1.25rem;
        }

        .book-card .card-title {
            font-size: 1.05rem;
            font-weight: 600;
            line-height: 1.4;
            color: var(--text-dark);
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

    .price {
        color: #e74c3c; /* Giữ giá tiền màu đỏ nổi */
        font-size: 1.35rem;
        font-weight: 700;
        margin: 0.5rem 0;
    }

    /* Button - Đổi sang màu chủ đạo rgba(25,36,50,1) */
    .btn-detail {
        border: 2px solid var(--primary);
        color: var(--primary);
        font-weight: 600;
        border-radius: 8px;
    }

        .btn-detail:hover {
            background: var(--primary);
            color: white;
        }

    .btn-add {
        background: var(--primary);
        color: white;
        font-weight: 600;
        border-radius: 8px;
    }

        .btn-add:hover {
            background: var(--primary-dark);
        }
</style>

<div class="container mt-5">

    <!-- CAROUSEL -->
    <div id="mainCarousel" class="carousel slide mb-5" data-bs-ride="carousel">
        <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="https://images.unsplash.com/photo-1512820790803-83ca734da794"
                     class="d-block w-100" alt="Banner 1">
            </div>
            <div class="carousel-item">
                <img src="https://images.unsplash.com/photo-1495446815901-a7297e633e8d"
                     class="d-block w-100" alt="Banner 2">
            </div>
            <div class="carousel-item">
                <img src="https://images.unsplash.com/photo-1524995997946-a1c2e315a42f"
                     class="d-block w-100" alt="Banner 3">
            </div>
        </div>

        <button class="carousel-control-prev" type="button" data-bs-target="#mainCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#mainCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
    </div>

    <!-- DANH MỤC -->
    <h3 class="section-title">Danh mục nổi bật</h3>
    <div class="row g-4 mb-5 text-center">
        <div class="col-md-3 col-6">
            <div class="category-card">📘 Lập trình</div>
        </div>
        <div class="col-md-3 col-6">
            <div class="category-card">📕 Kinh tế</div>
        </div>
        <div class="col-md-3 col-6">
            <div class="category-card">📗 Kỹ năng sống</div>
        </div>
        <div class="col-md-3 col-6">
            <div class="category-card">📙 Tiểu thuyết</div>
        </div>
    </div>

    <!-- SÁCH NỔI BẬT -->
    <h3 class="section-title">Sách nổi bật</h3>
    <div id="featured-books" class="row g-4 mb-5"></div>

    <!-- SÁCH BÁN CHẠY -->
    <h3 class="section-title">Sách bán chạy</h3>
    <div id="best-seller-books" class="row g-4"></div>
</div>

@section Scripts {
    <script>
        const API_BASE = "https://localhost:7287/api";
        const USER_ID = 1; // ⚠ tạm hardcode, sau này dùng session/login

        document.addEventListener("DOMContentLoaded", function () {
            loadFeaturedBooks();
            loadBestSellerBooks();
        });

        async function loadFeaturedBooks() {
            try {
                const response = await fetch(`${API_BASE}/home/featured-books`);
                const books = await response.json();
                renderBooks(books, "featured-books");
            } catch (error) {
                console.error("Lỗi load featured:", error);
            }
        }

        async function loadBestSellerBooks() {
            try {
                const response = await fetch(`${API_BASE}/home/featured-books`);
                const books = await response.json();
                renderBooks(books, "best-seller-books");
            } catch (error) {
                console.error("Lỗi load best seller:", error);
            }
        }

        function renderBooks(books, containerId) {
            const container = document.getElementById(containerId);
            container.innerHTML = "";

            if (!books || books.length === 0) {
                container.innerHTML = `<div class="col-12"><p class="text-center text-muted py-5">Không có sách.</p></div>`;
                return;
            }

            books.forEach(book => {
                container.innerHTML += `
                    <div class="col-md-3 col-sm-6 mb-4">
                        <div class="card book-card shadow-sm h-100">
                            <img src="${book.coverImageUrl ?? 'https://via.placeholder.com/300x400'}"
                                 class="card-img-top" alt="${book.title}">
                            <div class="card-body d-flex flex-column">
                                <h6 class="card-title">${book.title}</h6>
                                <p class="price">${book.price.toLocaleString()} VND</p>
                                <div class="mt-auto pt-2">
                                    <button class="btn btn-detail w-100 mb-2">Xem chi tiết</button>
                                    <button class="btn btn-add w-100"
                                            onclick="addToCart(${book.bookId})">
                                        🛒 Thêm vào giỏ
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            });
        }

        async function addToCart(bookId) {
            try {
                const response = await fetch(`${API_BASE}/cart/add`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        userId: USER_ID,
                        bookId: bookId,
                        quantity: 1
                    })
                });

                if (!response.ok) {
                    const text = await response.text();
                    console.error("SERVER ERROR:", text);
                    alert("❌ Lỗi server, xem Console");
                    return;
                }

                alert("✅ Đã thêm vào giỏ hàng!");
            } catch (error) {
                console.error("Lỗi thêm cart:", error);
                alert("❌ Có lỗi xảy ra!");
            }
        }
    </script>
}
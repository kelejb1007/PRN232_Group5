<style>
    .detail-wrapper {
        width: 90%;
        margin: 40px auto;
    }

    .detail-bg {
        background-color: #fff3e0;
        padding: 50px; /* tăng chiều cao */
        border-radius: 20px;
        min-height: 450px; /* tăng chiều dài */
    }
</style>

<div class="container mt-4">
    <div class="detail-bg shadow">
        <div class="row">
            <div class="col-md-4 text-center">
                <img src="@Model.CoverImageUrl"
                     class="img-fluid rounded shadow"
                     style="max-height:400px;" />
            </div>

            <div class="col-md-8">
                <h2>@Model.Title</h2>

                <h4 class="text-danger mb-3">
                    @Model.Price.ToString("N0") đ
                </h4>

                <p>@Model.Description</p>

                <div class="mt-4">
                    <!-- Add To Cart -->
                    <a href="/Cart/Add/@Model.BookId"
                       class="btn btn-warning text-white me-2">
                        Add To Cart
                    </a>

                    <!-- Back -->
                    <a href="/Search"
                       class="btn btn-secondary">
                        Back
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
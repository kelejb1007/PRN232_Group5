@model Intelligence_Book_WEB.Models.BookDetailViewModel
@{
    ViewData["Title"] = Model.Book.Title;
    var userToken = Context.Request.Cookies["access_token"];
    var isAuthenticated = !string.IsNullOrEmpty(userToken);
}

<style>
    :root {
        --primary-color: #192432;
        --accent-color: #f39c12;
        --text-muted: #6c757d;
        --bg-light: #f8f9fa;
        --star-color: #f1c40f;
    }

    .detail-wrapper {
        padding: 40px 0;
        background-color: var(--bg-light);
    }

    .detail-card {
        background: #ffffff;
        border-radius: 12px;
        border: none;
        overflow: hidden;
        display: flex;
        align-items: flex-start; /* Fix image to top-align */
    }

    .book-cover-wrapper {
        padding: 30px;
        background: #f1f3f5;
        display: flex;
        justify-content: center;
        align-items: flex-start; /* Start from top */
        min-width: 350px;
    }

    .book-cover {
        width: 100%;
        max-width: 350px;
        border-radius: 8px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        transition: transform 0.3s ease;
    }

    .book-cover:hover {
        transform: scale(1.02);
    }

    .product-info {
        padding: 30px 40px;
        flex-grow: 1;
    }

    .product-title {
        color: var(--primary-color);
        font-weight: 800;
        font-size: 2.2rem;
        margin-bottom: 5px;
        line-height: 1.2;
    }

    .product-meta {
        margin-bottom: 20px;
        font-size: 1.05rem;
    }

    .meta-item {
        margin-bottom: 8px;
        display: flex;
        gap: 10px;
    }

    .meta-label {
        font-weight: 600;
        color: var(--text-muted);
        min-width: 120px;
    }

    .product-price {
        font-size: 2rem;
        font-weight: 700;
        color: #d9534f;
        margin: 20px 0;
    }

    .description-container {
        position: relative;
        margin-bottom: 20px;
    }

    .product-description {
        color: #444;
        line-height: 1.7;
        font-size: 1.05rem;
        overflow: hidden;
        max-height: 150px; /* Limit height */
        transition: max-height 0.4s ease;
    }

    .product-description.expanded {
        max-height: 5000px;
    }

    .read-more-btn {
        background: none;
        border: none;
        color: var(--primary-color);
        font-weight: 600;
        padding: 5px 0;
        cursor: pointer;
        display: none; /* Only show via JS if needed */
        margin-top: 5px;
    }

    .btn-buy {
        background-color: var(--primary-color);
        color: white;
        padding: 15px 40px;
        border-radius: 8px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.2s;
        border: 2px solid var(--primary-color);
    }

    .btn-buy:hover {
        background-color: transparent;
        color: var(--primary-color);
    }

    /* Review Styles */
    .reviews-section {
        margin-top: 60px;
        padding: 40px;
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 15px rgba(0,0,0,0.05);
    }

    .review-card {
        border: none;
        border-bottom: 1px solid #eee;
        padding: 20px 0;
        transition: background 0.2s;
    }

    .review-card:last-child {
        border-bottom: none;
    }

    .star-rating i, .review-star i {
        color: var(--star-color);
        margin-right: 2px;
    }

    .cursor-pointer { cursor: pointer; }
</style>

<div class="detail-wrapper">
    <div class="container">
        <!-- Main Info -->
        <div class="detail-card shadow-sm">
            <div class="row g-0 w-100">
                <!-- Image Side -->
                <div class="col-md-5 col-lg-4 book-cover-wrapper">
                    <img src="@Model.Book.CoverImageUrl" class="book-cover" alt="@Model.Book.Title" />
                </div>

                <!-- Content Side -->
                <div class="col-md-7 col-lg-8 product-info">
                    <nav aria-label="breadcrumb">
                         <ol class="breadcrumb mb-4">
                            <li class="breadcrumb-item"><a href="/Home/Index" class="text-decoration-none" style="color: var(--text-muted)"><i class="fas fa-chevron-left me-1"></i> Quay lại cửa hàng</a></li>
                        </ol>
                    </nav>

                    <h1 class="product-title">@Model.Book.Title</h1>
                    
                    <div class="product-price">
                        @Model.Book.Price.ToString("N0") <span style="font-size: 1.1rem">VNĐ</span>
                    </div>

                    <div class="product-meta">
                        <div class="meta-item">
                            <span class="meta-label">Tác giả:</span>
                            <span>@(Model.Book.AuthorName ?? "Chưa rõ")</span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">Nhà xuất bản:</span>
                            <span>@(Model.Book.Publisher ?? "Đang cập nhật")</span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">Ngày xuất bản:</span>
                            <span>@(Model.Book.PublishDate?.ToString("dd/MM/yyyy") ?? "Đang cập nhật")</span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">ISBN:</span>
                            <span>@(Model.Book.ISBN ?? "N/A")</span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">Số lượng còn:</span>
                            <span class="badge @(Model.Book.StockQuantity > 0 ? "bg-success" : "bg-danger")">@Model.Book.StockQuantity</span>
                        </div>
                    </div>

                    <div class="description-container">
                        <div class="meta-label mb-2">Mô tả sản phẩm:</div>
                        <div id="descriptionText" class="product-description">
                            @Model.Book.Description
                        </div>
                        <button id="toggleDesc" class="read-more-btn">Xem thêm <i class="fas fa-chevron-down ms-1"></i></button>
                    </div>

                     <div class="mt-4">
                        @if (Model.Book.StockQuantity > 0) {
                            <button onclick="addToCart(@Model.Book.BookId)" class="btn btn-buy me-3">
                                <i class="bi bi-cart-plus me-2"></i> Thêm vào giỏ hàng
                            </button>
                        } else {
                            <button class="btn btn-secondary btn-lg disabled" disabled>Hết hàng</button>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Review Section -->
        <div class="reviews-section mt-5">
            <div class="d-flex justify-content-between align-items-center mb-5 pb-3 border-bottom">
                <h3 class="mb-0 fw-bold">Khách hàng nhận xét (@Model.Reviews.Count)</h3>
                
                @if (isAuthenticated)
                {
                    if (Model.CanReview)
                    {
                        <button class="btn btn-dark" data-bs-toggle="modal" data-bs-target="#reviewModal">
                            <i class="fas fa-pen-nib me-2"></i>Viết đánh giá
                        </button>
                    }
                    else if (Model.UserReview != null)
                    {
                        <button class="btn btn-outline-dark" data-bs-toggle="modal" data-bs-target="#reviewModal" 
                                onclick="populateEditForm('@Model.UserReview.ReviewId', '@Model.UserReview.Rating', '@Html.Raw(Model.UserReview.Comment)')">
                            <i class="fas fa-edit me-2"></i>Sửa đánh giá
                        </button>
                    }
                }
                else
                {
                    <span class="text-muted small">Vui lòng <a asp-controller="Auth" asp-action="Login">Đăng nhập</a> để đánh giá</span>
                }
            </div>

            @if (!Model.Reviews.Any())
            {
                <div class="text-center py-5">
                    <p class="text-muted italic">Sách hiện chưa có đánh giá nào.</p>
                </div>
            }
            else
            {
                <div class="review-list">
                    @foreach (var review in Model.Reviews)
                    {
                        <div class="review-card">
                            <div class="d-flex justify-content-between mb-2">
                                <strong class="text-dark">
                                    @(string.IsNullOrEmpty(review.UserName) ? "Người dùng ẩn danh" : review.UserName)
                                </strong>
                                <span class="text-muted small">@review.CreatedAt.ToString("dd/MM/yyyy")</span>
                            </div>
                            <div class="review-star mb-2">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="@(i <= review.Rating ? "fas" : "far") fa-star"></i>
                                }
                            </div>
                            <p class="text-secondary mb-0">@review.Comment</p>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal Đánh giá -->
<div class="modal fade" id="reviewModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Đánh giá của bạn</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 pt-2">
                <form id="reviewForm" class="text-center">
                    <input type="hidden" id="reviewId" value="">
                    <input type="hidden" id="bookId" value="@Model.Book.BookId">
                    
                    <div class="star-rating fs-2 mb-4">
                        <i class="far fa-star cursor-pointer" data-value="1"></i>
                        <i class="far fa-star cursor-pointer" data-value="2"></i>
                        <i class="far fa-star cursor-pointer" data-value="3"></i>
                        <i class="far fa-star cursor-pointer" data-value="4"></i>
                        <i class="far fa-star cursor-pointer" data-value="5"></i>
                        <input type="hidden" id="ratingInput" value="0">
                    </div>

                    <div class="form-group mb-4">
                        <textarea class="form-control" id="comment" rows="4" placeholder="Cảm nhận của bạn về cuốn sách này..."></textarea>
                    </div>

                    <button type="submit" class="btn btn-dark btn-lg w-100 py-3">Gửi đánh giá</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function addToCart(bookId) {
            try {
                const response = await fetch(`${API_BASE}/cart/add`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    credentials: "include",
                    body: JSON.stringify({ bookId: bookId, quantity: 1 })
                });

                if (response.status === 401) {
                    window.location.href = "/Auth/Login";
                    return;
                }

                if (!response.ok) {
                    alert("❌ Lỗi thêm vào giỏ hàng");
                    return;
                }

                alert("✅ Đã thêm vào giỏ hàng!");
                // (Tùy chọn) Reload count hoặc notify layout
                if (typeof loadCartCount === "function") loadCartCount();

            } catch (error) {
                console.error("Cart Error:", error);
            }
        }

        $(function () {
            // Check if description needs "Read More"
            const desc = $('#descriptionText');
            if (desc[0].scrollHeight > 150) {
                $('#toggleDesc').show();
            }

            $('#toggleDesc').on('click', function() {
                desc.toggleClass('expanded');
                if (desc.hasClass('expanded')) {
                    $(this).html('Thu gọn <i class="fas fa-chevron-up ms-1"></i>');
                } else {
                    $(this).html('Xem thêm <i class="fas fa-chevron-down ms-1"></i>');
                }
            });

            // Hover & Click Stars — scoped to modal form only, does NOT touch review-card stars
            let currentRating = 0;
            const $modalStars = $('#reviewForm .star-rating i');
            $modalStars.on('mouseover', function () {
                highlightStars($(this).data('value'));
            }).on('mouseout', function () {
                highlightStars(currentRating);
            }).on('click', function () {
                currentRating = $(this).data('value');
                $('#ratingInput').val(currentRating);
                highlightStars(currentRating);
            });

            function highlightStars(count) {
                $modalStars.each(function (idx) {
                    if (idx < count) $(this).removeClass('far').addClass('fas');
                    else $(this).removeClass('fas').addClass('far');
                });
            }

            // AJAX Submit
            $('#reviewForm').on('submit', function (e) {
                e.preventDefault();
                if ($('#ratingInput').val() == 0) {
                    alert('Vui lòng chọn số sao!');
                    return;
                }

                const data = {
                    reviewId: $('#reviewId').val() ? parseInt($('#reviewId').val()) : null,
                    bookId: parseInt($('#bookId').val()),
                    rating: parseInt($('#ratingInput').val()),
                    comment: $('#comment').val()
                };

                $.ajax({
                    url: '/Book/SubmitReview',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(data),
                    success: function (res) {
                        alert('Thành công!');
                        location.reload();
                    },
                    error: function (xhr) {
                        alert('Lỗi: ' + (xhr.responseJSON?.message || 'Không thể gửi đánh giá.'));
                    }
                });
            });
        });

        function populateEditForm(id, rating, comment) {
            $('#reviewId').val(id);
            $('#ratingInput').val(parseInt(rating));
            $('#comment').val(comment);
            currentRating = parseInt(rating);
            highlightStars(currentRating);
        }
    </script>
}

@{
    ViewData["Title"] = "Thanh toán đã hủy";
}

<div class="container mt-5">
    <div class="card shadow border-0">
        <div class="card-body text-center p-5">
            <div class="mb-3">
                <span style="font-size: 60px;">❌</span>
            </div>

            <h2 class="text-danger mb-3">Thanh toán đã bị hủy</h2>

            <p class="text-muted mb-4">
                Bạn đã hủy giao dịch hoặc giao dịch chưa hoàn tất.
            </p>

            <div class="d-flex justify-content-center gap-2">
                <a href="/Cart/Checkout" class="btn btn-warning">Thử thanh toán lại</a>
                <a href="/Cart" class="btn btn-outline-secondary">Quay lại giỏ hàng</a>
            </div>
        </div>
    </div>
</div>
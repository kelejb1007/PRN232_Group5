@{
    ViewData["Title"] = "Thanh toán";
}

<div class="container mt-5">
    <h3 class="mb-4">Xác nhận đơn hàng</h3>

    <!-- CART -->
    <div id="cart-container" class="mb-4"></div>

    <!-- FORM ĐỊA CHỈ -->
    <div class="mb-3">
        <input id="name" class="form-control mb-2" placeholder="Tên người nhận" />
        <input id="phone" class="form-control mb-2" placeholder="SĐT" />
        <input id="address" class="form-control mb-2" placeholder="Địa chỉ giao hàng" />
    </div>

    <!-- COUPON -->
    <div class="mb-3">
        <label for="coupon-list" class="form-label">Chọn mã giảm giá</label>
        <select id="coupon-list" class="form-select">
            <option value="">-- Không dùng coupon --</option>
        </select>
        <small id="coupon-msg" class="text-danger"></small>
    </div>

    <!-- CHECKOUT -->
    <div class="text-end mt-3">
        <button id="btn-checkout" class="btn btn-success">Thanh toán</button>
    </div>
</div>

@section Scripts {
<script>
// =========================
// Base URL API
// =========================
window.API_BASE = window.API_BASE || "https://localhost:7287/api";

let cartTotal = 0;        
let discountAmount = 0;    
let cartLoaded = false;

// =========================
// Load cart + coupon khi mở trang
// =========================
document.addEventListener("DOMContentLoaded", () => {
    loadCart();
    loadCoupons();

    const select = document.getElementById("coupon-list");
    select.addEventListener("change", () => {
        const code = select.value;
        if(!code){
            resetDiscount();
        } else if(cartLoaded){
            applyCoupon(code);
        }
    });

    // Attach checkout
    document.getElementById("btn-checkout").addEventListener("click", checkout);
});

// =========================
// Load cart từ API
// =========================
async function loadCart() {
    try {
        const resCart = await fetch(`${window.API_BASE}/cart`, { credentials: "include" });
        if (!resCart.ok) { console.error(await resCart.text()); return; }
        const carts = await resCart.json();

        renderCart(carts);
        cartLoaded = true;

        // Nếu user đã chọn coupon trước đó, apply lại
        const select = document.getElementById("coupon-list");
        if(select.value) applyCoupon(select.value);

    } catch (err) {
        console.error(err);
    }
}

// =========================
// Load danh sách coupon từ API
// =========================
async function loadCoupons() {
    try {
        const res = await fetch(`${window.API_BASE}/coupon/list`, { credentials: "include" });
        if(!res.ok) { console.error(await res.text()); return; }
        const coupons = await res.json(); // [{code:"XMAS20", discountPercent:20}, ...]

        const select = document.getElementById("coupon-list");
        coupons.forEach(c => {
            const option = document.createElement("option");
            option.value = c.code;
            option.text = `${c.code} - Giảm ${Math.round(c.discountPercent)}%`;
            select.appendChild(option);
        });

        // Nếu server trả coupon đang dùng, chỉ apply khi cartLoaded
        const resCurrent = await fetch(`${window.API_BASE}/coupon/current`, { credentials: "include" });
        if(resCurrent.ok){
            const data = await resCurrent.json();
            if(data?.code){
                select.value = data.code;
                if(cartLoaded){
                    discountAmount = data.discountAmount;
                    updateTotals();
                }
            }
        }

    } catch(err) {
        console.error(err);
    }
}

// =========================
// Render cart + totals
// =========================
function renderCart(carts){
    const container = document.getElementById("cart-container");
    if(!carts || carts.length===0){
        container.innerHTML="<div>Giỏ hàng trống</div>";
        cartTotal=0;
        discountAmount=0;
        updateTotals();
        return;
    }

    let html="", total=0;
    carts.forEach(item=>{
        const price=item.book?.price??0;
        const title=item.book?.title??"Không có tên";
        const sub=item.quantity*price;
        total+=sub;

        html+=`
        <div class="d-flex justify-content-between border-bottom py-2">
            <div><b>${title}</b><br/><small>${item.quantity} x ${price.toLocaleString()} VND</small></div>
            <div>${sub.toLocaleString()} VND</div>
        </div>`;
    });

    html+=`
    <div class="mt-3 p-3 border rounded bg-light">
        <div class="d-flex justify-content-between"><span>Tạm tính:</span><span id="subtotal">${total.toLocaleString()} VND</span></div>
        <div class="d-flex justify-content-between text-success"><span>Giảm giá:</span><span id="discount">${discountAmount.toLocaleString()} VND</span></div>
        <hr/>
        <div class="d-flex justify-content-between fw-bold fs-5"><span>Tổng cộng:</span><span id="final-total">${(total - discountAmount).toLocaleString()} VND</span></div>
    </div>`;

    container.innerHTML = html;
    cartTotal = total;
}

// =========================
// Apply coupon
// =========================
async function applyCoupon(code){
    if(!code || cartTotal===0) return resetDiscount();

    try{
        const res = await fetch(`${window.API_BASE}/coupon/apply?code=${code}&total=${cartTotal}`, { credentials: "include" });
        const msgEl = document.getElementById("coupon-msg");

        if(!res.ok){
            discountAmount=0;
            msgEl.innerText = await res.text();
        }else{
            const data = await res.json();
            discountAmount = data.discountAmount || 0;
            msgEl.innerText = "";
        }
        updateTotals();
    }catch(err){
        console.error(err);
        discountAmount=0;
        updateTotals();
        document.getElementById("coupon-msg").innerText="Lỗi hệ thống";
    }
}

// =========================
// Update hiển thị tổng
// =========================
function updateTotals(){
    document.getElementById("discount").innerText = discountAmount.toLocaleString() + " VND";
    document.getElementById("final-total").innerText = (cartTotal - discountAmount).toLocaleString() + " VND";
}

// =========================
// Reset discount
// =========================
function resetDiscount(){
    discountAmount=0;
    updateTotals();
    document.getElementById("coupon-msg").innerText="";
}

// =========================
// Checkout
// =========================
async function checkout(){
    const name = document.getElementById("name").value.trim();
    const phone = document.getElementById("phone").value.trim();
    const address = document.getElementById("address").value.trim();
    const coupon = document.getElementById("coupon-list").value.trim();

    if(!name || !phone || !address){ alert("Nhập đầy đủ thông tin!"); return; }

    try{
        const res = await fetch(`${window.API_BASE}/cart/checkout`, {
            method:"POST",
            headers:{ "Content-Type":"application/json" },
            credentials:"include",
            body:JSON.stringify({
                receiverName:name,
                phoneNumber:phone,
                shippingAddress:address,
                couponCode:coupon
            })
        });

        if(!res.ok){ alert("Checkout lỗi: "+await res.text()); return; }

        const data = await res.json();
        window.location.href = data.checkoutUrl;

    }catch(err){
        console.error(err);
        alert("Lỗi hệ thống!");
    }
}
</script>
}
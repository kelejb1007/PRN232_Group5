@{
    ViewData["Title"] = "Thanh toán";
}

<div class="container mt-5">
    <h3>Xác nhận đơn hàng</h3>

    <!-- CART -->
    <div id="cart-container"></div>

    <!-- FORM ĐỊA CHỈ -->
    <div class="mt-3">
        <input id="name" class="form-control mb-2" placeholder="Tên người nhận" />
        <input id="phone" class="form-control mb-2" placeholder="SĐT" />
        <input id="address" class="form-control mb-2" placeholder="Địa chỉ giao hàng" />
    </div>

    <div class="text-end mt-3">
        <button onclick="checkout()" class="btn btn-success">
            Thanh toán
        </button>
    </div>
</div>

@section Scripts {
<script>
    const API_BASE = "https://localhost:7287/api";

    document.addEventListener("DOMContentLoaded", () => {
        loadCart();
    });

    // =========================
    // LOAD CART (FIX JWT)
    // =========================
    async function loadCart() {
        try {
            const res = await fetch(`${API_BASE}/cart`, {
                credentials: "include"
            });

            if (res.status === 401) {
                window.location.href = "/Auth/Login";
                return;
            }

            if (!res.ok) {
                const text = await res.text();
                console.error("Load cart lỗi:", text);
                return;
            }

            const carts = await res.json();
            renderCart(carts);

        } catch (err) {
            console.error("Load cart lỗi:", err);
        }
    }

    // =========================
    // RENDER
    // =========================
    function renderCart(carts) {
        const container = document.getElementById("cart-container");

        if (!carts || carts.length === 0) {
            container.innerHTML = `<div>Giỏ hàng trống</div>`;
            return;
        }

        let html = "";
        let total = 0;

        carts.forEach(item => {
            const price = item.book?.price ?? 0;
            const title = item.book?.title ?? "Không có tên";
            const sub = item.quantity * price;
            total += sub;

            html += `
                <div class="border p-2 mb-2">
                    <b>${title}</b>
                    - ${item.quantity} x ${price.toLocaleString()} VND
                </div>
            `;
        });

        html += `<h4>Tổng: ${total.toLocaleString()} VND</h4>`;
        container.innerHTML = html;
    }

    // =========================
    // CHECKOUT (FIX JWT)
    // =========================
    async function checkout() {
        const name = document.getElementById("name").value.trim();
        const phone = document.getElementById("phone").value.trim();
        const address = document.getElementById("address").value.trim();

        if (!name || !phone || !address) {
            alert("Nhập đầy đủ thông tin!");
            return;
        }

        try {
            const res = await fetch(`${API_BASE}/cart/checkout`, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                credentials: "include", // 🔥 QUAN TRỌNG
                body: JSON.stringify({
                    receiverName: name,
                    phoneNumber: phone,
                    shippingAddress: address
                })
            });

            if (!res.ok) {
                const text = await res.text();
                alert("Checkout lỗi: " + text);
                return;
            }

            const data = await res.json();

            if (!data.checkoutUrl) {
                alert("Không có link thanh toán!");
                return;
            }

            // 👉 redirect PayOS
            window.location.href = data.checkoutUrl;

        } catch (err) {
            console.error(err);
            alert("Lỗi hệ thống!");
        }
    }
</script>
}
}
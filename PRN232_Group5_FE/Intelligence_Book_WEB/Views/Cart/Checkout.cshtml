@{
    ViewData["Title"] = "Thanh toán";
}

<div class="container mt-5">
    <h3>Xác nhận đơn hàng</h3>

    <!-- CART -->
    <div id="cart-container"></div>

    <!-- FORM ĐỊA CHỈ -->
    <div class="mt-3">
        <input id="name" class="form-control mb-2" placeholder="Tên người nhận" />
        <input id="phone" class="form-control mb-2" placeholder="SĐT" />
        <input id="address" class="form-control mb-2" placeholder="Địa chỉ giao hàng" />
    </div>

    <div class="text-end mt-3">
        <button onclick="checkout()" class="btn btn-success">
            Thanh toán
        </button>
    </div>
</div>

@section Scripts {
    <script>
        const API_BASE = "https://localhost:7287/api";
        const USER_ID = 1;

        document.addEventListener("DOMContentLoaded", () => {
            loadCart();
        });

        // =========================
        // LOAD CART
        // =========================
        async function loadCart() {
            try {
                const res = await fetch(`${API_BASE}/cart/${USER_ID}`);

                if (!res.ok) {
                    const text = await res.text();
                    console.error("Load cart lỗi API:", res.status, text);
                    document.getElementById("cart-container").innerHTML = `
                        <div class="text-danger">Không tải được giỏ hàng</div>
                    `;
                    return;
                }

                const carts = await res.json();
                const container = document.getElementById("cart-container");

                if (!carts || carts.length === 0) {
                    container.innerHTML = `
                        <div class="text-center text-muted">
                            Giỏ hàng trống
                        </div>
                    `;
                    return;
                }

                let html = "";
                let total = 0;

                carts.forEach(item => {
                    const price = item.book?.price ?? 0;
                    const title = item.book?.title ?? "Không có tên sách";
                    const sub = item.quantity * price;
                    total += sub;

                    html += `
                        <div class="border p-2 mb-2">
                            <b>${title}</b>
                            - ${item.quantity} x ${price.toLocaleString()} VND
                        </div>
                    `;
                });

                html += `<h4>Tổng: ${total.toLocaleString()} VND</h4>`;
                container.innerHTML = html;

            } catch (err) {
                console.error("Load cart lỗi:", err);
                document.getElementById("cart-container").innerHTML = `
                    <div class="text-danger">Có lỗi khi tải giỏ hàng</div>
                `;
            }
        }

        // =========================
        // CHECKOUT
        // =========================
        async function checkout() {
            const name = document.getElementById("name").value.trim();
            const phone = document.getElementById("phone").value.trim();
            const address = document.getElementById("address").value.trim();

            if (!name || !phone || !address) {
                alert("Vui lòng nhập đầy đủ thông tin!");
                return;
            }

            try {
                const res = await fetch(`${API_BASE}/cart/checkout`, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        userId: USER_ID,
                        receiverName: name,
                        phoneNumber: phone,
                        shippingAddress: address
                    })
                });

                const text = await res.text();
                console.log("STATUS:", res.status);
                console.log("RESPONSE:", text);

                if (!res.ok) {
                    alert("Thanh toán thất bại: " + text);
                    return;
                }

                const data = JSON.parse(text);

                if (!data.checkoutUrl) {
                    alert("Không nhận được link thanh toán!");
                    return;
                }

                window.location.href = data.checkoutUrl;

            } catch (err) {
                console.error("Checkout lỗi:", err);
                alert("Có lỗi xảy ra: " + err.message);
            }
        }
    </script>
}
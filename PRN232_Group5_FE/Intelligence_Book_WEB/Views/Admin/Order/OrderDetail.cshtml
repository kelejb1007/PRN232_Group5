@model Intelligence_Book_WEB.Models.Dto.OrderDetailVm
@using Intelligence_Book_WEB.Models.Enums
@{
    ViewData["Title"] = "Chi Tiết Đơn Hàng #" + Model.OrderId;
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    
    string vnStatusText = Model.Status switch {
        OrderStatus.Pending => "Chờ xử lý",
        OrderStatus.Processing => "Đang xử lý",
        OrderStatus.Delivered => "Hoàn thành",
        OrderStatus.Cancelled => "Đã hủy",
        OrderStatus.Shipped => "Đang giao",
        _ => Model.Status.ToString()
    };
    
    decimal itemsTotal = Model.OrderItems?.Sum(i => i.TotalPrice) ?? 0;
}

<style>
    .order-header {
        background-color: #111827;
        color: white;
        padding: 30px;
        border-radius: 15px;
        border-bottom: 5px solid #c5a059;
        margin-bottom: 30px;
    }
    .info-card {
        background: #fff;
        border-radius: 15px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        height: 100%;
        border: none;
    }
    .card-label { color: #6b7280; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; }
    .card-value { color: #111827; font-weight: 700; }
    .status-badge-lg {
        padding: 8px 15px;
        border-radius: 30px;
        font-weight: 800;
        font-size: 0.9rem;
    }
    .table-dark-header thead {
        background-color: #111827;
        color: #fff;
    }
    .table-dark-header thead th { border-bottom: 3px solid #c5a059; }
    .summary-line { display: flex; justify-content: space-between; padding: 10px 0; }
    .summary-total { border-top: 2px solid #eee; padding-top: 15px; font-size: 1.25rem; font-weight: 800; color: #dc2626; }
</style>

<div class="order-detail p-3 animate-fade-in shadow-sm" style="border-radius: 15px; background: #fdfdfd;">
    <div class="mb-4">
        <a href="/Admin/Order/OrderList" class="btn btn-outline-secondary btn-sm px-3 hover-lift">
            <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
        </a>
    </div>

    <div class="order-header shadow-lg d-flex justify-content-between align-items-center">
        <div>
            <h2 class="m-0 fw-bold">Đơn hàng #@Model.OrderId</h2>
            <p class="mb-0 opacity-75">Ngày đặt: @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
        </div>
        <div class="text-end">
            <span class="status-badge-lg bg-warning text-dark shadow-sm">@vnStatusText</span>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="card info-card p-4 shadow-sm border-0">
                <h5 class="fw-bold mb-4 text-primary border-bottom pb-2">Thông tin khách hàng</h5>
                <div class="mb-3">
                    <div class="card-label">Họ tên</div>
                    <div class="card-value fs-5">@(string.IsNullOrEmpty(Model.CustomerName) ? "—" : Model.CustomerName)</div>
                </div>
                <div class="mb-3">
                    <div class="card-label">Địa chỉ giao hàng</div>
                    <div class="card-value">@(string.IsNullOrEmpty(Model.ShippingAddress) ? "Chưa cập nhật" : Model.ShippingAddress)</div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card info-card p-4 shadow-sm border-0">
                <h5 class="fw-bold mb-4 text-primary border-bottom pb-2">Chi tiết thanh toán</h5>
                @if (!string.IsNullOrEmpty(Model.CouponCode))
                {
                    <div class="mb-3">
                        <div class="card-label">Mã giảm giá</div>
                        <div class="card-value"><span class="badge bg-success">@Model.CouponCode</span> (@Model.CouponDiscountPercentage%)</div>
                    </div>
                }
                <div class="mb-3">
                    <div class="card-label">Phương thức</div>
                    <div class="card-value">Thanh toán khi nhận hàng (COD)</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card info-card overflow-hidden shadow-sm border-0">
        <div class="px-4 pt-4">
            <h5 class="fw-bold mb-3">Danh sách sản phẩm</h5>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle table-dark-header mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Sản Phẩm</th>
                        <th class="text-end">Đơn Giá</th>
                        <th class="text-center">Số Lượng</th>
                        <th class="text-end pe-4">Thành Tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.OrderItems != null && Model.OrderItems.Any())
                    {
                        foreach (var item in Model.OrderItems)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@item.BookName</div>
                                    <small class="text-muted">ID: #@item.BookId</small>
                                </td>
                                <td class="text-end">@item.PriceAtPurchase.ToString("N0") đ</td>
                                <td class="text-center fw-bold">@item.Quantity</td>
                                <td class="text-end pe-4 fw-bold">@item.TotalPrice.ToString("N0") đ</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer bg-light p-4 border-0">
            <div class="row justify-content-end">
                <div class="col-md-4">
                    <div class="summary-line">
                        <span class="text-muted">Tổng tiền hàng:</span>
                        <span class="fw-bold">@itemsTotal.ToString("N0") đ</span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.CouponCode))
                    {
                        <div class="summary-line text-success">
                            <span>Giảm giá (@Model.CouponCode):</span>
                            <span class="fw-bold">-@((itemsTotal - Model.TotalAmount).ToString("N0")) đ</span>
                        </div>
                    }
                    <div class="summary-line summary-total">
                        <span>TỔNG CỘNG:</span>
                        <span>@Model.TotalAmount.ToString("N0") đ</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

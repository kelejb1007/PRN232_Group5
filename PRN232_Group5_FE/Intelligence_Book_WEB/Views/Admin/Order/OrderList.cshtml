@model Intelligence_Book_WEB.Models.Dto.PagedResultVm<Intelligence_Book_WEB.Models.Dto.OrderVm>
@using Intelligence_Book_WEB.Models.Enums
@{
    ViewData["Title"] = "Quản lý Đơn hàng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    string search = (ViewBag.Search as string) ?? "";
    OrderStatus? currentStatus = ViewBag.Status as OrderStatus?;
    int pageSize = Model.PageSize > 0 ? Model.PageSize : 5;
}

<style>
    .status-badge {
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }
    .status-badge::before {
        content: "";
        display: block;
        width: 6px;
        height: 6px;
        border-radius: 50%;
    }
    .status-pending { background-color: #fef3c7; color: #92400e; }
    .status-pending::before { background-color: #d97706; }
    .status-processing { background-color: #e0f2fe; color: #075985; }
    .status-processing::before { background-color: #0ea5e9; }
    .status-delivered { background-color: #dcfce7; color: #166534; }
    .status-delivered::before { background-color: #22c55e; }
    .status-cancelled { background-color: #fee2e2; color: #991b1b; }
    .status-cancelled::before { background-color: #ef4444; }
    .status-shipped { background-color: #ede9fe; color: #5b21b6; }
    .status-shipped::before { background-color: #8b5cf6; }

    .order-row:hover { background-color: #f9fafb; cursor: pointer; }
    .btn-gold { background-color: #c5a059; border: none; color: #fff; font-weight: 600; }
    .btn-gold:hover { background-color: #b08d48; color: #fff; }
    
    .warning-note {
        color: #ea580c;
        font-weight: 600;
        font-size: 0.8rem;
        display: flex;
        align-items: center;
        gap: 5px;
    }
</style>

<div class="order-management p-3 animate-fade-in">
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <h2 class="m-0 fw-bold text-dark">Quản lý Đơn hàng</h2>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" style="border-left: 5px solid #10b981 !important;">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm overflow-hidden" style="border-radius: 15px;">
        <div class="card-header bg-white py-4 border-0">
            <form method="get" action="/Admin/Order/OrderList" class="row g-3">
                <div class="col-md-5">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-search"></i></span>
                        <input type="text" name="search" value="@search" class="form-control bg-light border-start-0" 
                               placeholder="Tìm mã đơn hoặc tên khách...">
                    </div>
                </div>
                <div class="col-md-3">
                    <select name="status" class="form-select bg-light">
                        <option value="">Tất cả trạng thái</option>
                        <option value="Pending" selected="@(currentStatus?.ToString() == "Pending")">Chờ xử lý</option>
                        <option value="Processing" selected="@(currentStatus?.ToString() == "Processing")">Đang xử lý</option>
                        <option value="Delivered" selected="@(currentStatus?.ToString() == "Delivered")">Hoàn thành</option>
                        <option value="Cancelled" selected="@(currentStatus?.ToString() == "Cancelled")">Đã hủy</option>
                    </select>
                </div>
                <div class="col-md-4 d-flex gap-2">
                    <button type="submit" class="btn btn-dark px-4 shadow-sm hover-lift">Lọc</button>
                    <a href="/Admin/Order/OrderList" class="btn btn-outline-secondary px-3">Làm mới</a>
                </div>
            </form>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-dark text-white">
                    <tr style="border-bottom: 3px solid #c5a059;">
                        <th class="ps-4">Mã Đơn</th>
                        <th>Khách Hàng</th>
                        <th>Ngày Đặt</th>
                        <th>Tổng Tiền</th>
                        <th>Trạng Thái</th>
                        <th>Ghi Chú</th>
                        <th class="text-end pe-4">Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted fst-italic">Không tìm thấy đơn hàng nào.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var o in Model.Items)
                        {
                            string statusClass = o.Status switch {
                                OrderStatus.Pending => "status-pending",
                                OrderStatus.Processing => "status-processing",
                                OrderStatus.Delivered => "status-delivered",
                                OrderStatus.Cancelled => "status-cancelled",
                                OrderStatus.Shipped => "status-shipped",
                                _ => ""
                            };
                            string vnStatusText = o.Status switch {
                                OrderStatus.Pending => "Chờ xử lý",
                                OrderStatus.Processing => "Đang xử lý",
                                OrderStatus.Delivered => "Hoàn thành",
                                OrderStatus.Cancelled => "Đã hủy",
                                OrderStatus.Shipped => "Đang giao",
                                _ => o.Status.ToString()
                            };

                            <tr class="order-row" onclick="if(!event.target.closest('form') && !event.target.closest('button')) window.location.href='/Admin/Order/Detail/@o.OrderId'">
                                <td class="ps-4 fw-bold">#@o.OrderId</td>
                                <td>@(string.IsNullOrEmpty(o.CustomerName) ? "—" : o.CustomerName)</td>
                                <td class="text-muted">@o.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="fw-bold">@o.TotalAmount.ToString("N0") <small>đ</small></td>
                                <td><span class="status-badge @statusClass">@vnStatusText</span></td>
                                <td>
                                    @if ((o.Status == OrderStatus.Processing || o.Status == OrderStatus.Shipped) && (DateTime.Now - o.OrderDate).TotalDays >= 3)
                                    {
                                        <div class="warning-note">
                                            <i class="bi bi-exclamation-triangle-fill"></i> > 3 ngày chưa nhận
                                        </div>
                                    }
                                    else { <span class="text-muted small">—</span> }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end gap-1">
                                        @if (o.Status == OrderStatus.Pending || o.Status == OrderStatus.Processing)
                                        {
                                            OrderStatus nextStatus = o.Status == OrderStatus.Pending ? OrderStatus.Processing : OrderStatus.Delivered;
                                            string btnClass = o.Status == OrderStatus.Pending ? "btn-outline-primary" : "btn-gold";
                                            string btnIcon = o.Status == OrderStatus.Pending ? "bi-check2-circle" : "bi-box-seam";
                                            
                                            <form method="post" action="/Admin/Order/UpdateStatus" onsubmit="return confirm('Xác nhận cập nhật trạng thái đơn hàng?');" style="margin:0;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@o.OrderId" />
                                                <input type="hidden" name="newStatus" value="@nextStatus" />
                                                <button type="submit" class="btn @btnClass btn-sm rounded-pill px-3 shadow-sm hover-lift" title="Cập nhật trạng thái">
                                                    <i class="bi @btnIcon me-1"></i> @(o.Status == OrderStatus.Pending ? "Xác nhận" : "Giao xong")
                                                </button>
                                            </form>

                                            <form method="post" action="/Admin/Order/Cancel" onsubmit="return confirm('Hủy đơn hàng này?');" style="margin:0;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@o.OrderId" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill hover-lift" title="Hủy đơn hàng">
                                                    <i class="bi bi-x-circle"></i>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <a href="/Admin/Order/Detail/@o.OrderId" class="btn btn-outline-secondary btn-sm rounded-pill px-3 shadow-sm hover-lift">
                                                <i class="bi bi-eye"></i> Chi tiết
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="card-footer bg-white py-4 border-0">
                <nav>
                    <ul class="pagination justify-content-center mb-0 shadow-sm">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.Page ? "active" : "")">
                                <a class="page-link @(i == Model.Page ? "bg-dark border-dark text-white" : "text-dark")" 
                                   href="/Admin/Order/OrderList?page=@i&pageSize=@pageSize&search=@Uri.EscapeDataString(search)&status=@currentStatus">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

@if (TempData["Message"] != null)
{
    var msg = TempData["Message"]?.ToString() ?? "";
    bool isError = msg.Contains("thất bại") || msg.Contains("Lỗi") || msg.Contains("failed", StringComparison.OrdinalIgnoreCase) || msg.Contains("Error", StringComparison.OrdinalIgnoreCase);
    string toastClass = isError ? "toast-error" : "toast-success";
    
    <div id="toast" class="toast @toastClass">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            @if(isError) {
                <circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line>
            } else {
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline>
            }
        </svg>
        @msg
    </div>
    <script>
        setTimeout(() => {
            const t = document.getElementById('toast');
            if (!t) return;
            t.classList.add('hide');
            setTimeout(() => t.remove(), 500);
        }, 3000);
    </script>
}

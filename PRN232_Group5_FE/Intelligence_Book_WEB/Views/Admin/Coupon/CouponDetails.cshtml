@model Intelligence_Book_WEB.Models.Dto.CouponVm
@{
    ViewData["Title"] = "Chi tiết Coupon";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var isUnlimited = !Model.ExpiryDate.HasValue || Model.ExpiryDate.Value.Year >= 2099;
    var isExpired = !isUnlimited && Model.ExpiryDate.Value.Date < DateTime.Today;
}

<style>
    .detail-card {
        background: #fff;
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        overflow: hidden;
    }
    .detail-header {
        background-color: #111827;
        color: white;
        padding: 20px 30px;
        border-bottom: 4px solid #c5a059;
    }
    .info-label { color: #6b7280; font-size: 0.85rem; font-weight: 600; text-transform: uppercase; margin-bottom: 5px; }
    .info-value { color: #111827; font-size: 1.1rem; font-weight: 700; margin-bottom: 20px; }
    .btn-gold { background-color: #c5a059; border: none; color: #fff; font-weight: 600; }
    .btn-gold:hover { background-color: #b08d48; color: #fff; }
    .code-box {
        background-color: #f9fafb;
        border: 2px dashed #c5a059;
        color: #111827;
        font-family: 'Courier New', Courier, monospace;
        font-size: 2.5rem;
        padding: 20px;
        text-align: center;
        border-radius: 10px;
        letter-spacing: 5px;
    }
</style>

<div class="coupon-details p-3 animate-fade-in">
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <a href="/Admin/Coupon/CouponList" class="btn btn-outline-secondary btn-sm px-3 hover-lift">
            <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
        </a>
        <h2 class="m-0 fw-bold text-dark">Chi tiết Coupon</h2>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show mb-4 border-0 shadow-sm" style="border-left: 5px solid #3b82f6 !important;">
            <i class="bi bi-info-circle-fill me-2"></i> @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="detail-card row g-0">
        <div class="col-md-5 detail-header d-flex flex-column justify-content-center align-items-center">
            <div class="code-box w-100 mb-3">@Model.Code</div>
            <div class="text-center">
                <div class="fs-1 fw-bold text-warning">@Model.DiscountPercent%</div>
                <div class="text-light opacity-75">GIẢM GIÁ</div>
            </div>
        </div>
        <div class="col-md-7 p-5 bg-white">
            <div class="row">
                <div class="col-sm-6">
                    <div class="info-label">Mã ID</div>
                    <div class="info-value">#@Model.CouponId</div>
                </div>
                <div class="col-sm-6">
                    <div class="info-label">Trạng thái</div>
                    <div class="info-value">
                        @if (isUnlimited) { <span class="badge bg-secondary">Vô thời hạn</span> }
                        else if (isExpired) { <span class="badge bg-danger">Đã hết hạn</span> }
                        else { <span class="badge bg-success">Đang hoạt động</span> }
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="info-label">Ngày hết hạn</div>
                    <div class="info-value">@(isUnlimited ? "—" : Model.ExpiryDate?.ToString("dd/MM/yyyy"))</div>
                </div>
                <div class="col-sm-6">
                    <div class="info-label">Số lượng còn lại</div>
                    <div class="info-value text-primary">@Model.quantity</div>
                </div>
            </div>

            <div class="mt-4 pt-4 border-top d-flex gap-2">
                @if (!isExpired)
                {
                    <a href="/Admin/Coupon/CouponUpdate?id=@Model.CouponId" class="btn btn-gold px-4 hover-lift">
                        <i class="bi bi-pencil-square me-1"></i> Chỉnh sửa
                    </a>
                }
                <form method="post" action="/Admin/Coupon/CouponDelete" onsubmit="return confirm('Bạn có chắc chắn muốn XÓA coupon này?');" style="margin:0;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.CouponId" />
                    <button type="submit" class="btn btn-outline-danger px-4 hover-lift">
                        <i class="bi bi-trash me-1"></i> Xóa Coupon
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
         </div>
            </div>
        </div>
    </div>
</div>
@model Intelligence_Book_WEB.Models.Dto.PagedResultVm<Intelligence_Book_WEB.Models.Dto.CouponVm>
@{
    ViewData["Title"] = "Quản lý Coupon";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    string search = (ViewBag.Search as string) ?? "";
    int pageSize = Model.PageSize > 0 ? Model.PageSize : 5;
}

<style>
    .coupon-search-panel {
        background-color: #1f2937;
        border-radius: 10px;
        padding: 14px 20px;
        margin-bottom: 20px;
    }
    .coupon-search-panel label { color: #d1d5db; font-size: 0.82rem; margin-bottom: 4px; display: block; }
    .coupon-search-panel .form-control {
        background-color: #111827;
        color: #f9fafb;
        border-color: #374151;
        font-size: 0.875rem;
    }
    .coupon-search-panel .form-control::placeholder { color: #6b7280; }
    .coupon-search-panel .form-control:focus {
        border-color: #c5a059;
        box-shadow: 0 0 0 0.15rem rgba(197,160,89,0.3);
    }
    .btn-gold { background-color: #c5a059; border: none; color: #fff; font-weight: 600; }
    .btn-gold:hover { background-color: #b08d48; color: #fff; }
    
    .badge-status { padding: 4px 10px; border-radius: 9999px; font-size: 0.75rem; font-weight: 600; }
    .status-available { background-color: #dcfce7; color: #16a34a; }
    .status-expired { background-color: #fee2e2; color: #dc2626; }
    .status-unlimited { background-color: #f1f5f9; color: #475569; }
</style>

<div class="coupon-page animate-fade-in p-3">
    <div class="d-flex justify-content-between align-items-center mb-4 rounded shadow-sm"
         style="background-color: #111827; border-left: 5px solid #c5a059; padding: 20px;">
        <h2 class="text-white m-0 fw-bold">
            <i class="bi bi-ticket-perforated me-2" style="color: #c5a059;"></i> Quản lý Coupon
        </h2>
    </div>

    <!-- Search Bar -->
    <form method="get" action="/Admin/Coupon/CouponList" class="coupon-search-panel">
        <div class="row g-2 align-items-end">
            <div class="col-md-6">
                <label><i class="bi bi-search me-1" style="color:#c5a059;"></i> Tìm kiếm mã giảm giá</label>
                <input type="text" name="search" class="form-control form-control-sm"
                       placeholder="Nhập mã code hoặc mức giảm..."
                       value="@search" />
                <input type="hidden" name="pageSize" value="@pageSize" />
            </div>
            <div class="col-auto d-flex gap-2">
                <button type="submit" class="btn btn-gold btn-sm px-4 hover-lift">
                    <i class="bi bi-search me-1"></i> Tìm
                </button>
                @if (!string.IsNullOrEmpty(search))
                {
                    <a href="/Admin/Coupon/CouponList" class="btn btn-sm btn-outline-secondary px-3 hover-lift"
                       style="color:#d1d5db; border-color:#4b5563;">
                        <i class="bi bi-x-circle me-1"></i> Xóa
                    </a>
                }
            </div>
        </div>
    </form>

    <!-- Coupon Table -->
    <div class="bg-white p-4 shadow-sm rounded">
        <div class="mb-3 d-flex justify-content-between align-items-center">
            <span class="text-muted small">
                Tìm thấy <strong>@Model.TotalItems</strong> mã giảm giá
            </span>
            <a href="/Admin/Coupon/CouponCreate" class="btn text-white fw-bold hover-lift" style="background-color: #c5a059; border: none;">
                <i class="bi bi-plus-circle me-1"></i> Thêm Coupon mới
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle border">
                <thead style="background-color: #1f2937; color: #d1d5db;">
                    <tr>
                        <th class="py-3">Mã Code</th>
                        <th class="py-3 text-center">Giảm Giá</th>
                        <th class="py-3 text-center">Ngày Hết Hạn</th>
                        <th class="py-3 text-center">Trạng Thái</th>
                        <th class="py-3 text-center">Số Lượng</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items != null && Model.Items.Any())
                    {
                        foreach (var c in Model.Items)
                        {
                            var neverExpire = !c.ExpiryDate.HasValue || c.ExpiryDate.Value.Year >= 2099;
                            var isExpired = !neverExpire && c.ExpiryDate.Value.Date < DateTime.Today;
                            <tr onclick="location.href='/Admin/Coupon/CouponDetails?id=@c.CouponId'" style="cursor: pointer;">
                                <td class="fw-bold fs-5 text-uppercase" style="font-family: monospace;">@c.Code</td>
                                <td class="text-center fw-bold text-danger">@c.DiscountPercent%</td>
                                <td class="text-center text-muted">
                                    @(neverExpire ? "—" : c.ExpiryDate?.ToString("dd/MM/yyyy"))
                                </td>
                                <td class="text-center">
                                    @if (neverExpire) { <span class="badge-status status-unlimited">Vô thời hạn</span> }
                                    else if (isExpired) { <span class="badge-status status-expired">Hết hạn</span> }
                                    else { <span class="badge-status status-available">Sử dụng được</span> }
                                </td>
                                <td class="text-center fw-bold">@c.quantity</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-search fs-2 d-block mb-2 opacity-50"></i>
                                Không tìm thấy mã giảm giá nào.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link" href="/Admin/Coupon/CouponList?page=@i&pageSize=@pageSize&search=@Uri.EscapeDataString(search)"
                               style="@(i == Model.Page ? "background-color: #c5a059; border-color: #c5a059;" : "color: #1f2937;")">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</div>

@if (TempData["Message"] != null)
{
    var msg = TempData["Message"]?.ToString() ?? "";
    bool isError = msg.Contains("thất bại") || msg.Contains("Lỗi") || msg.Contains("failed", StringComparison.OrdinalIgnoreCase) || msg.Contains("Error", StringComparison.OrdinalIgnoreCase);
    string toastClass = isError ? "toast-error" : "toast-success";
    
    <div id="toast" class="toast @toastClass">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            @if(isError) {
                <circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line>
            } else {
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline>
            }
        </svg>
        @msg
    </div>
    <script>
        setTimeout(() => {
            const t = document.getElementById('toast');
            if (!t) return;
            t.classList.add('hide');
            setTimeout(() => t.remove(), 500);
        }, 3000);
    </script>
}
@model Intelligence_Book_WEB.Models.PagedResultVm<Intelligence_Book_WEB.Models.CouponVm>
@{
    ViewData["Title"] = "Coupon List";
    string search = (ViewBag.Search as string) ?? "";
    int pageSize = Model.PageSize > 0 ? Model.PageSize : 5;
}

<style>
    body {
        font-family: Arial, sans-serif;
        background: #f5f6f8;
    }

    .wrap {
        padding: 24px;
    }

    .card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 10px 18px rgba(0,0,0,.08);
        padding: 20px;
    }

    .top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
    }

    .btn {
        padding: 10px 14px;
        border-radius: 10px;
        border: none;
        cursor: pointer;
        font-weight: 700;
        text-decoration: none;
        display: inline-block;
    }

    .btn-green {
        background: #16a34a;
        color: #fff;
    }

    .btn-blue {
        background: #2563eb;
        color: #fff;
    }

    .filter {
        margin-top: 16px;
        background: #eef0f3;
        padding: 12px;
        border-radius: 12px;
        display: flex;
        gap: 12px;
        align-items: center;
        flex-wrap: wrap;
    }

    input {
        padding: 10px;
        border: 1px solid #d1d5db;
        border-radius: 10px;
        min-width: 260px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 16px;
        background: #fff;
    }

    th, td {
        border: 1px solid #e5e7eb;
        padding: 10px;
    }

    th {
        background: #fb923c;
        color: #fff;
        text-align: center;
    }

    tr:hover {
        background: #f3f4f6;
        cursor: pointer;
    }

    /* ✅ expired row mờ đi */
    tr.row-expired {
        opacity: .65;
    }

        tr.row-expired:hover {
            background: #f8fafc;
        }
    /* hover nhẹ thôi */

    .badge {
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 800;
        display: inline-block;
    }

    .ok {
        color: #16a34a;
        background: #dcfce7;
    }

    .bad {
        color: #dc2626;
        background: #fee2e2;
    }

    .neutral {
        color: #0f172a;
        background: #e2e8f0;
    }
    /* never expire */

    .paging {
        margin-top: 14px;
        text-align: center;
    }

        .paging a {
            display: inline-block;
            padding: 8px 12px;
            margin: 0 3px;
            background: #e5e7eb;
            border-radius: 10px;
            text-decoration: none;
            color: #111827;
            font-weight: 700;
        }

            .paging a.active {
                background: #fb923c;
                color: #fff;
            }

    .toast {
        position: fixed;
        top: 16px;
        right: 16px;
        padding: 12px 16px;
        border-radius: 12px;
        color: white;
        font-weight: 800;
        box-shadow: 0 12px 18px rgba(0,0,0,.15);
        opacity: 1;
        transition: opacity .5s ease;
        z-index: 9999;
    }

        .toast.hide {
            opacity: 0;
        }

    .toast-success {
        background: #16a34a;
    }
</style>

<div class="wrap">
    <div class="card">
        <div class="top">
            <h2 style="margin:0;">📌 Coupon List</h2>
            <a class="btn btn-green" href="/Admin/Coupon/CouponCreate">+ Add New Coupon</a>
        </div>

        <form class="filter" method="get" action="/Admin/Coupon/CouponList">
            <input name="search" value="@search" placeholder="Search by code / id / percent..." style="flex:1;min-width:260px;" />
            <input type="hidden" name="pageSize" value="@pageSize" />
            <button class="btn btn-blue" type="submit">Search</button>
        </form>

        <div style="overflow:auto;border-radius:12px;">
            <table>
                <thead>
                    <tr>
                        @* <th style="width:80px;">ID</th> *@
                        <th style="width:260px;">Code</th>
                        <th style="width:140px;">Discount</th>
                        <th style="width:220px;">Expiry Date</th>
                        <th style="width:140px;">Status</th>
                        <th style="width:160px;">Quantity</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items == null || Model.Items.Count == 0)
                    {
                        <tr>
                            <td colspan="6" style="text-align:center;color:#6b7280;font-style:italic;">No coupon found.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var c in Model.Items)
                        {
                            var neverExpire = !c.ExpiryDate.HasValue;
                            var isExpired = c.ExpiryDate.HasValue && c.ExpiryDate.Value.Date < DateTime.Today;

                            <tr class="@(isExpired ? "row-expired" : "")"
                                onclick="location.href='/Admin/Coupon/CouponDetails?id=@c.CouponId'">
                                @* <td style="text-align:center;">@c.CouponId</td> *@
                                <td style="font-weight:800;">@c.Code</td>
                                <td style="text-align:center;">@c.DiscountPercent %</td>
                                <td style="text-align:center;">@(c.ExpiryDate?.ToString("yyyy-MM-dd") ?? "-")</td>

                                <td style="text-align:center;">
                                    @if (neverExpire)
                                    {
                                        <span class="badge neutral">Never expire</span>
                                    }
                                    else if (isExpired)
                                    {
                                        <span class="badge bad">Expired</span>
                                    }
                                    else
                                    {
                                        <span class="badge ok">Available</span>
                                    }
                                </td>

                                <td style="text-align:center;">@c.quantity</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="paging">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    var activeClass = i == Model.Page ? "active" : "";
                    <a class="@activeClass"
                       href="/Admin/Coupon/CouponList?page=@i&pageSize=@pageSize&search=@Uri.EscapeDataString(search)">
                        @i
                    </a>
                }
            </div>
        }
    </div>
</div>

@if (TempData["Message"] != null)
{
    <div id="toast" class="toast toast-success">@TempData["Message"]</div>
    <script>
        setTimeout(() => {
            const t = document.getElementById('toast');
            if (!t) return;
            t.classList.add('hide');
            setTimeout(() => t.remove(), 500);
        }, 2500);
    </script>
}
@model Intelligence_Book_WEB.Models.Dto.CouponVm
@{
    var isEdit = Model.CouponId != 0;
    ViewData["Title"] = isEdit ? "Cập nhật Coupon" : "Thêm Coupon";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .form-card {
        background: #fff;
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        padding: 40px;
        max-width: 700px;
        margin: 0 auto;
    }
    .form-label { font-weight: 700; color: #374151; margin-bottom: 8px; font-size: 0.9rem; }
    .form-control {
        border-radius: 10px;
        padding: 12px 15px;
        border: 1px solid #d1d5db;
        transition: all 0.2s;
    }
    .form-control:focus {
        border-color: #c5a059;
        box-shadow: 0 0 0 0.2rem rgba(197,160,89,0.25);
    }
    .btn-gold { background-color: #c5a059; border: none; color: #fff; font-weight: 600; padding: 12px 25px; border-radius: 10px; }
    .btn-gold:hover { background-color: #b08d48; color: #fff; }
    .section-header {
        background-color: #111827;
        color: white;
        padding: 15px 25px;
        border-radius: 10px;
        border-left: 5px solid #c5a059;
        margin-bottom: 30px;
    }
</style>

<div class="coupon-form p-3 animate-fade-in">
    <div class="mb-4">
        <a href="/Admin/Coupon/CouponList" class="btn btn-outline-secondary btn-sm px-3 hover-lift">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </a>
    </div>

    <div class="form-card shadow-lg">
        <div class="section-header">
            <h4 class="m-0 fw-bold"><i class="bi bi-pencil-square me-2"></i> @(isEdit ? "Cập nhật mã giảm giá" : "Tạo mã giảm giá mới")</h4>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger border-0 shadow-sm mb-4">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.Error
            </div>
        }

        <form id="couponForm" method="post" action="/Admin/Coupon/CouponSave">
            @Html.AntiForgeryToken()
            <input type="hidden" name="CouponId" value="@Model.CouponId" />

            <div class="mb-4">
                <label class="form-label">Mã Coupon (Code)</label>
                <div class="input-group">
                    <input id="Code" name="Code" value="@Model.Code" class="form-control fw-bold text-uppercase" 
                           style="letter-spacing: 2px;" readonly required />
                    @if (!isEdit)
                    {
                        <button class="btn btn-dark" type="button" id="btnRandom">
                            <i class="bi bi-shuffle me-1"></i> Ngẫu nhiên
                        </button>
                    }
                </div>
                <small class="text-muted">Mã được sinh tự động để đảm bảo tính duy nhất.</small>
            </div>

            <div class="row">
                <div class="col-md-6 mb-4">
                    <label class="form-label">Phần trăm giảm (%)</label>
                    <input id="DiscountPercent" type="number" name="DiscountPercent" value="@Model.DiscountPercent" 
                           class="form-control" min="1" max="50" required @(isEdit ? "readonly" : "") />
                    <small class="text-muted">Từ 1% đến 50%.</small>
                </div>
                <div class="col-md-6 mb-4">
                    <label class="form-label">Số lượng</label>
                    <input id="quantity" type="number" name="quantity" value="@Model.quantity" 
                           class="form-control" min="0" required />
                    <small class="text-muted">Số lượt sử dụng tối đa.</small>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label">Ngày hết hạn</label>
                <input id="ExpiryDate" type="date" name="ExpiryDate" 
                       value="@(Model.ExpiryDate?.ToString("yyyy-MM-dd") ?? "")" class="form-control" />
                <small class="text-muted">Để trống nếu mã không bao giờ hết hạn.</small>
            </div>

            <div class="mt-4 pt-3 border-top text-end">
                <button type="submit" class="btn btn-gold px-5 shadow-sm hover-lift">
                    <i class="bi bi-check-circle me-1"></i> @(isEdit ? "Lưu thay đổi" : "Tạo Coupon")
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    (function() {
        const btnRandom = document.getElementById('btnRandom');
        const codeInput = document.getElementById('Code');
        
        if (btnRandom) {
            function generateCode() {
                const chars = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789";
                let code = "CP";
                for (let i = 0; i < 8; i++) {
                    code += chars.charAt(Math.floor(Math.random() * chars.length));
                }
                return code;
            }
            
            btnRandom.onclick = () => { codeInput.value = generateCode(); };
            if (!codeInput.value) codeInput.value = generateCode();
        }
    })();
</script>

<script>
(function () {
    const isEdit = @((Model.CouponId != 0).ToString().ToLower());

    const form = document.getElementById("couponForm");
    const clientError = document.getElementById("clientError");

    const codeEl = document.getElementById("Code");
    const discountEl = document.getElementById("DiscountPercent");
    const expiryEl = document.getElementById("ExpiryDate");
    const qtyEl = document.getElementById("quantity");
    const btnRandom = document.getElementById("btnRandom");

    function todayStr() {
        const d = new Date();
        const yyyy = d.getFullYear();
        const mm = String(d.getMonth() + 1).padStart(2, "0");
        const dd = String(d.getDate()).padStart(2, "0");
        return `${yyyy}-${mm}-${dd}`;
    }

    const today = todayStr();

    // set min date để không chọn ngày quá khứ
    expiryEl.setAttribute("min", today);

    // UPDATE: khóa Code & Discount
    if (isEdit) {
        codeEl.readOnly = true;
        discountEl.readOnly = true;
    } else {
        codeEl.readOnly = true; // create cũng không cho nhập tay
        discountEl.readOnly = false;
    }

    // random code thực tế: CP + 8 ký tự (A-Z0-9) tránh nhầm
    function randomCode() {
        const chars = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789"; // bỏ I,O,1,0
        let s = "CP";
        for (let i = 0; i < 8; i++) s += chars[Math.floor(Math.random() * chars.length)];
        return s;
    }

    function normalizeCode(v) {
        v = (v || "").toUpperCase().trim();
        v = v.replace(/[^A-Z0-9]/g, "");
        return v;
    }

    // Create: auto sinh code nếu trống + nút random
    if (btnRandom) {
        btnRandom.addEventListener("click", function () {
            codeEl.value = randomCode();
        });
        if (!codeEl.value || !codeEl.value.trim()) {
            codeEl.value = randomCode();
        }
    }

    function showError(msg) {
        const icon = `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="min-width: 20px;"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>`;
        clientError.innerHTML = icon + "&nbsp;" + msg;
        clientError.style.display = "flex";
    }

    function clearError() {
        clientError.innerHTML = "";
        clientError.style.display = "none";
        [codeEl, discountEl, expiryEl, qtyEl].forEach(x => x.classList.remove("field-error"));
    }

    function mark(el) { if (el) el.classList.add("field-error"); }

    function clampInt(el, min, max) {
        el.addEventListener("input", function () {
            if (el.value === "") return;
            let v = parseInt(el.value, 10);
            if (Number.isNaN(v)) return;
            if (v < min) v = min;
            if (v > max) v = max;
            el.value = v;
        });
    }

    clampInt(discountEl, 1, 50);
    clampInt(qtyEl, 0, 10000);

    form.addEventListener("submit", function (e) {
        clearError();

        // normalize code
        codeEl.value = normalizeCode(codeEl.value);

        const code = codeEl.value;
        const discount = parseInt(discountEl.value, 10);
        const qty = parseInt(qtyEl.value, 10);
        const expiry = (expiryEl.value || "").trim();

        // Code: 6-20, chỉ A-Z0-9
        if (!code) {
            e.preventDefault();
            showError("Mã không được để trống. Vui lòng tạo tự động.");
            mark(codeEl);
            return;
        }
        if (code.length < 6 || code.length > 20) {
            e.preventDefault();
            showError("Mã phải dài từ 6 tới 20 ký tự (A-Z, 0-9).");
            mark(codeEl);
            return;
        }
        if (!/^[A-Z0-9]+$/.test(code)) {
            e.preventDefault();
            showError("Mã chỉ được chứa chữ in hoa và số (A-Z, 0-9).");
            mark(codeEl);
            return;
        }

        // Discount 1-50
        if (!Number.isInteger(discount) || discount < 1 || discount > 50) {
            e.preventDefault();
            showError("Phần trăm giảm giá phải nằm trong khoảng từ 1 tới 50.");
            mark(discountEl);
            return;
        }

        // Quantity 0-10000
        if (!Number.isInteger(qty) || qty < 0 || qty > 10000) {
            e.preventDefault();
            showError("Số lượng khả dụng chỉ được từ 0 tới 10000.");
            mark(qtyEl);
            return;
        }

        // ExpiryDate: nếu có chọn thì không quá khứ
        if (expiry && expiry < today) {
            e.preventDefault();
            showError("Ngày hết hạn không được thuộc về quá khứ.");
            mark(expiryEl);
            return;
        }

        // Logic thực tế: quantity = 0 => confirm
        if (qty === 0) {
            const ok = confirm("Số lượng = 0 có nghĩa là Coupon tạm thời vô hiệu hóa. Bạn có muốn lưu tiếp?");
            if (!ok) {
                e.preventDefault();
                mark(qtyEl);
                return;
            }
        }

        if (isEdit) {
            // bảo vệ khỏi devtools
            codeEl.readOnly = true;
            discountEl.readOnly = true;
        }
    });

})();
</script>
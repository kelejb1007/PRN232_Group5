@model Intelligence_Book_WEB.Models.CouponVm
@{
    var isEdit = Model.CouponId != 0;
    ViewData["Title"] = isEdit ? "Update Coupon" : "Add Coupon";
}

<style>
    body { font-family: Arial, sans-serif; background: #f5f6f8; }
    .wrap { padding: 24px; }
    .card { background:#fff; border-radius:16px; box-shadow:0 10px 18px rgba(0,0,0,.08); padding:22px; max-width:980px; margin:0 auto; }
    .title { font-size:26px; font-weight:900; margin:0 0 12px; }
    .grid { display:grid; grid-template-columns:1fr 1fr; gap:14px 22px; }
    label { font-weight:800; color:#111827; display:block; margin-bottom:6px; }
    input { width:100%; padding:10px; border:1px solid #d1d5db; border-radius:12px; }
    input[readonly], input:disabled { background:#f3f4f6; cursor:not-allowed; }
    .btn { padding:10px 16px; border-radius:12px; border:none; cursor:pointer; font-weight:900; text-decoration:none; display:inline-block; }
    .btn-orange { background:#fb923c; color:#fff; }
    .btn-blue { background:#2563eb; color:#fff; }
    .btn-gray { background:#111827; color:#fff; }
    .error { margin:12px 0; padding:10px 14px; border-radius:12px; background:#fee2e2; color:#991b1b; font-weight:800; }
    .hint { font-size:12px; color:#6b7280; margin-top:6px; }
    .field-error { border-color:#dc2626 !important; box-shadow:0 0 0 2px rgba(220,38,38,.12); }
</style>

<div class="wrap">
    <div style="max-width:980px;margin:0 auto 12px;display:flex;justify-content:space-between;align-items:center;">
        <h2 class="title">@(isEdit ? "Update Coupon" : "Add New Coupon")</h2>
        <a class="btn btn-blue" href="/Admin/Coupon/CouponList">← Back</a>
    </div>

    <div class="card">
        @if (ViewBag.Error != null)
        {
            <div class="error">@ViewBag.Error</div>
        }

        <div id="clientError" class="error" style="display:none;"></div>

        <form id="couponForm" method="post" action="/Admin/Coupon/CouponSave" novalidate>
            @Html.AntiForgeryToken()

            <input type="hidden" name="CouponId" value="@Model.CouponId" />

            <div class="grid">
                <div>
                    <label>Code</label>
                    <div style="display:flex; gap:10px; align-items:center;">
                        <input id="Code" name="Code"
                               value="@Model.Code"
                               maxlength="50"
                               required
                               readonly />
                        @if (!isEdit)
                        {
                            <button id="btnRandom" type="button" class="btn btn-gray" style="white-space:nowrap;">
                                Random
                            </button>
                        }
                    </div>
                    <div class="hint">Code tự tạo, không nhập tay. Format: A-Z, 0-9.</div>
                </div>

                <div>
                    <label>Discount Percent (1-50)</label>
                    <input id="DiscountPercent" type="number"
                           name="DiscountPercent"
                           value="@Model.DiscountPercent"
                           min="1"
                           max="50"
                           step="1"
                           required
                           @(isEdit ? "readonly" : "") />
                    <div class="hint">Chỉ cho nhập từ 1 tới 50.</div>
                </div>

                <div>
                    <label>Expiry Date</label>
                    <input id="ExpiryDate" type="date"
                           name="ExpiryDate"
                           value="@(Model.ExpiryDate?.ToString("yyyy-MM-dd") ?? "")" />
                    <div class="hint">Không được chọn ngày trong quá khứ. Để trống nếu không muốn hết hạn.</div>
                </div>

                <div>
                    <label>Quantity (0-1000)</label>
                    <input id="quantity" type="number"
                           name="quantity"
                           value="@Model.quantity"
                           min="0"
                           max="1000"
                           step="1"
                           required />
                    <div class="hint">Chỉ cho nhập từ 1 tới 1000. Quantity = 0 là coupon không dùng được.</div>
                </div>
            </div>

            <div style="margin-top:18px;">
                <button class="btn btn-orange" type="submit">
                    @(isEdit ? "Update" : "Create")
                </button>
            </div>
        </form>
    </div>
</div>

<script>
(function () {
    const isEdit = @((Model.CouponId != 0).ToString().ToLower());

    const form = document.getElementById("couponForm");
    const clientError = document.getElementById("clientError");

    const codeEl = document.getElementById("Code");
    const discountEl = document.getElementById("DiscountPercent");
    const expiryEl = document.getElementById("ExpiryDate");
    const qtyEl = document.getElementById("quantity");
    const btnRandom = document.getElementById("btnRandom");

    function todayStr() {
        const d = new Date();
        const yyyy = d.getFullYear();
        const mm = String(d.getMonth() + 1).padStart(2, "0");
        const dd = String(d.getDate()).padStart(2, "0");
        return `${yyyy}-${mm}-${dd}`;
    }

    const today = todayStr();

    // set min date để không chọn ngày quá khứ
    expiryEl.setAttribute("min", today);

    // UPDATE: khóa Code & Discount
    if (isEdit) {
        codeEl.readOnly = true;
        discountEl.readOnly = true;
    } else {
        codeEl.readOnly = true; // create cũng không cho nhập tay
        discountEl.readOnly = false;
    }

    // random code thực tế: CP + 8 ký tự (A-Z0-9) tránh nhầm
    function randomCode() {
        const chars = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789"; // bỏ I,O,1,0
        let s = "CP";
        for (let i = 0; i < 8; i++) s += chars[Math.floor(Math.random() * chars.length)];
        return s;
    }

    function normalizeCode(v) {
        v = (v || "").toUpperCase().trim();
        v = v.replace(/[^A-Z0-9]/g, "");
        return v;
    }

    // Create: auto sinh code nếu trống + nút random
    if (btnRandom) {
        btnRandom.addEventListener("click", function () {
            codeEl.value = randomCode();
        });
        if (!codeEl.value || !codeEl.value.trim()) {
            codeEl.value = randomCode();
        }
    }

    function showError(msg) {
        clientError.textContent = msg;
        clientError.style.display = "block";
    }

    function clearError() {
        clientError.textContent = "";
        clientError.style.display = "none";
        [codeEl, discountEl, expiryEl, qtyEl].forEach(x => x.classList.remove("field-error"));
    }

    function mark(el) { if (el) el.classList.add("field-error"); }

    function clampInt(el, min, max) {
        el.addEventListener("input", function () {
            if (el.value === "") return;
            let v = parseInt(el.value, 10);
            if (Number.isNaN(v)) return;
            if (v < min) v = min;
            if (v > max) v = max;
            el.value = v;
        });
    }

    clampInt(discountEl, 1, 50);
    clampInt(qtyEl, 0, 1000);

    form.addEventListener("submit", function (e) {
        clearError();

        // normalize code
        codeEl.value = normalizeCode(codeEl.value);

        const code = codeEl.value;
        const discount = parseInt(discountEl.value, 10);
        const qty = parseInt(qtyEl.value, 10);
        const expiry = (expiryEl.value || "").trim();

        // Code: 6-20, chỉ A-Z0-9
        if (!code) {
            e.preventDefault();
            showError("Code không được để trống. Bấm Random để tạo code.");
            mark(codeEl);
            return;
        }
        if (code.length < 6 || code.length > 20) {
            e.preventDefault();
            showError("Code phải dài từ 6 tới 20 ký tự (A-Z, 0-9).");
            mark(codeEl);
            return;
        }
        if (!/^[A-Z0-9]+$/.test(code)) {
            e.preventDefault();
            showError("Code chỉ được chứa chữ in hoa và số (A-Z, 0-9).");
            mark(codeEl);
            return;
        }

        // Discount 1-50
        if (!Number.isInteger(discount) || discount < 1 || discount > 50) {
            e.preventDefault();
            showError("Discount Percent chỉ được từ 1 tới 50.");
            mark(discountEl);
            return;
        }

        // Quantity 0-1000
        if (!Number.isInteger(qty) || qty < 1 || qty > 1000) {
            e.preventDefault();
            showError("Quantity chỉ được từ 1 tới 1000.");
            mark(qtyEl);
            return;
        }

        // ExpiryDate: nếu có chọn thì không quá khứ
        if (expiry && expiry < today) {
            e.preventDefault();
            showError("Expiry Date không được chọn ngày trong quá khứ.");
            mark(expiryEl);
            return;
        }

        // Logic thực tế: quantity = 0 => confirm
        if (qty === 0) {
            const ok = confirm("Quantity = 0 nghĩa là coupon không dùng được. Bạn vẫn muốn lưu?");
            if (!ok) {
                e.preventDefault();
                mark(qtyEl);
                return;
            }
        }

        // Logic thực tế: UPDATE không cho chỉnh khi coupon đã expired
        // (nếu muốn vẫn cho update expired -> nói mình, mình bỏ rule này)
        if (isEdit) {
            const originalExpiry = "@(Model.ExpiryDate?.ToString("yyyy-MM-dd") ?? "")";
            // xác định expired dựa trên current expiry (nếu có)
            const expiredNow = originalExpiry && originalExpiry < today;
            if (expiredNow) {
                e.preventDefault();
                showError("Coupon đã hết hạn nên không cho Update.");
                return;
            }

            // bảo vệ khỏi devtools
            codeEl.readOnly = true;
            discountEl.readOnly = true;
        }
    });
})();
</script>
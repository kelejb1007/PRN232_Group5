<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Intelligence Book</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- ===== NAVBAR ===== -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
            <div class="container">

                <!-- LOGO -->
                <a class="navbar-brand fw-bold fs-4"
                   asp-controller="Home"
                   asp-action="Index">
                    📚 Intelligence Book
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">

                    <!-- DANH MỤC -->
                    <ul class="navbar-nav me-3">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle"
                               href="#"
                               data-bs-toggle="dropdown">
                                Danh mục
                            </a>
                             <ul class="dropdown-menu">
                                 @foreach (var cate in (ViewBag.Categories as List<Intelligence_Book_WEB.Models.CategoryViewModel>) ?? new List<Intelligence_Book_WEB.Models.CategoryViewModel>())
                                 {
                                     <li><a class="dropdown-item" href="/?categoryId=@cate.CategoryId">@cate.CategoryName</a></li>
                                 }
                            </ul>
                        </li>
                    </ul>

                    <!-- SEARCH -->
                     <form class="d-flex flex-grow-1 me-3" action="/" method="get">
                        <input class="form-control me-2"
                               type="search"
                               name="search"
                               value="@ViewBag.SearchTerm"
                               placeholder="Tìm sách, tác giả..." />
                        <button class="btn btn-warning" type="submit">Tìm</button>
                    </form>

                    <!-- ICONS -->
                    <ul class="navbar-nav align-items-center">

                        <li class="nav-item me-3">
                            <a class="nav-link" href="#">
                                ❤️
                            </a>
                        </li>
                        <li class="nav-item me-3 position-relative">
                            <a class="nav-link position-relative"
                               asp-controller="Cart"
                               asp-action="Index">

                                🛒

                                <span id="cart-count"
                                      class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                    0
                                </span>

                            </a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle"
                               href="#"
                               data-bs-toggle="dropdown"
                               id="nav-account-toggle">
                                👤 <span id="nav-account-text">Tài khoản</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">

                                <!-- CHƯA LOGIN -->
                                <li id="nav-login" style="display: @(Context.Request.Cookies.ContainsKey("access_token") ? "none" : "block")">
                                    <a class="dropdown-item" href="/Auth/Login">Đăng nhập</a>
                                </li>
                                <li id="nav-register" style="display: @(Context.Request.Cookies.ContainsKey("access_token") ? "none" : "block")">
                                    <a class="dropdown-item" href="/Auth/Register">Đăng ký</a>
                                </li>

                                <!-- ĐÃ LOGIN -->
                                <li id="nav-profile" style="display: @(Context.Request.Cookies.ContainsKey("access_token") ? "block" : "none")">
                                    <a class="dropdown-item" href="/Profile">
                                        <i class="bi bi-person me-2"></i>Hồ sơ của tôi
                                    </a>
                                </li>
                                <li id="nav-orders" style="display: @(Context.Request.Cookies.ContainsKey("access_token") ? "block" : "none")">
                                    <a class="dropdown-item" href="/Order/History">
                                        <i class="bi bi-box-seam me-2"></i>Lịch sử đơn hàng
                                    </a>
                                </li>
                                <li id="nav-dashboard" style="display: none;">
                                    <a class="dropdown-item text-primary fw-bold" href="/Dashboard">
                                        <i class="bi bi-speedometer2 me-2"></i>Dashboard
                                    </a>
                                </li>
                                <li id="nav-logout" style="display: @(Context.Request.Cookies.ContainsKey("access_token") ? "block" : "none")">
                                    <form asp-area="" asp-controller="Auth" asp-action="Logout" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                                        </button>
                                    </form>
                                </li>

                            </ul>
                        </li>
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <!-- ===== BODY ===== -->
    <div class="container mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- ===== FOOTER ===== -->
    <footer class="bg-dark text-white mt-5 pt-4 pb-3">
        <div class="container text-center">
            <p class="mb-1">© 2026 Intelligence Book Store</p>
            <small>Website bán sách ASP.NET Core MVC</small>
        </div>
    </footer>

    <!-- ===== SCRIPTS ===== -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        const API_BASE = "https://localhost:7287/api";

        function getCookie(name) {
            let value = `; ${document.cookie}`;
            let parts = value.split(`; ${name}=`);
            if (parts.length === 2) return parts.pop().split(';').shift();
        }

        function parseJwt(token) {
            try {
                var base64Url = token.split('.')[1];
                var base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
                var jsonPayload = decodeURIComponent(window.atob(base64).split('').map(function (c) {
                    return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
                }).join(''));
                return JSON.parse(jsonPayload);
            } catch (e) {
                return null;
            }
        }

        document.addEventListener("DOMContentLoaded", () => {
            const token = getCookie("access_token");

            const login = document.getElementById("nav-login");
            const register = document.getElementById("nav-register");
            const profile = document.getElementById("nav-profile");
            const orders = document.getElementById("nav-orders");
            const dashboard = document.getElementById("nav-dashboard");
            const logoutBtn = document.getElementById("nav-logout");
            const accountText = document.getElementById("nav-account-text");

            if (token) {
                if (login) login.style.display = "none";
                if (register) register.style.display = "none";
                if (profile) profile.style.display = "block";
                if (orders) orders.style.display = "block";
                if (logoutBtn) logoutBtn.style.display = "block";

                const payload = parseJwt(token);
                if (payload) {
                    // Check name (Replace "Tài khoản" with Name)
                    const name = payload["unique_name"] ||
                        payload["uniqueName"] ||
                        payload["name"] ||
                        payload["http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name"] ||
                        payload["sub"];

                    console.log("User detected:", name);
                    if (accountText && name) accountText.innerText = name;

                    // Check role
                    const role = payload["role"] || payload["http://schemas.microsoft.com/ws/2008/06/identity/claims/role"];
                    if (role === "Admin") {
                        if (dashboard) dashboard.style.display = "block";
                    }
                }
            } else {
                if (login) login.style.display = "block";
                if (register) register.style.display = "block";
                if (profile) profile.style.display = "none";
                if (orders) orders.style.display = "none";
                if (dashboard) dashboard.style.display = "none";
                if (logoutBtn) logoutBtn.style.display = "none";
                if (accountText) accountText.innerText = "Tài khoản";
            }

            loadCartCount();
        });

        async function loadCartCount() {
            try {
                const res = await fetch(`${API_BASE}/cart`, {
                    credentials: "include"
                });

                if (res.status === 401) {
                    document.getElementById("cart-count").innerText = "0";
                    return;
                }

                const data = await res.json();
                document.getElementById("cart-count").innerText = data.length || 0;

            } catch { }
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
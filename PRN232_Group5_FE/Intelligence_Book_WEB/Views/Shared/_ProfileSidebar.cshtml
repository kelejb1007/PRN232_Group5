@using Models.UserAccount
@{
    var profileInfo = ViewBag.ProfileInfo as AuthDTO.UserProfileDTO;
    var activeTab = ViewBag.ActiveTab?.ToString() ?? "personal";
}

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-4">
        <div class="text-center mb-4">
            <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px; font-size: 2rem;">
                @(profileInfo?.Username?.Substring(0, 1).ToUpper() ?? "U")
            </div>
            <h5 class="fw-bold mb-0">@profileInfo?.Username</h5>
            <p class="text-muted small">@profileInfo?.Email</p>
        </div>
        <div class="nav flex-column nav-pills" id="profile-tabs">
            <a class="nav-link text-start mb-2 @(activeTab == "personal" ? "active" : "")" asp-controller="Profile" asp-action="Index">
                <i class="bi bi-person me-2"></i> Thông tin cá nhân
            </a>
            <a class="nav-link text-start mb-2 @(activeTab == "addresses" ? "active" : "")" asp-controller="Address" asp-action="Index">
                <i class="bi bi-geo-alt me-2"></i> Địa chỉ nhận hàng
            </a>
            <a class="nav-link text-start mb-2 @(activeTab == "orders" ? "active" : "")" asp-controller="Order" asp-action="History">
                <i class="bi bi-bag me-2"></i> Lịch sử đơn hàng
            </a>
        </div>
    </div>
</div>

<style>
    .nav-pills .nav-link {
        color: #495057;
        border-radius: 8px;
        font-weight: 500;
        border: 1px solid transparent;
    }
    .nav-pills .nav-link.active {
        background-color: #f8f9fa;
        color: var(--bs-primary);
        border-left: 4px solid var(--bs-primary);
        border-radius: 0 8px 8px 0;
    }
    .nav-pills .nav-link:hover:not(.active) {
        background-color: #f8f9fa;
    }
</style>

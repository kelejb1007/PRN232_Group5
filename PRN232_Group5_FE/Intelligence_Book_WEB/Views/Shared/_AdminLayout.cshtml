@* new - updated to match old structure *@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - YUMMY Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/Admin_layout.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    @RenderSection("Styles", required: false)
</head>
<body>
    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="logo-section">
            <h1 style="color:#F79356;">YUMMY</h1>
            <p>Admin Dashboard - Book Management System</p>
        </div>

        <div class="user-info">
            <i class="bi bi-person-circle" style="font-size: 2rem; color: #F79356;"></i>
            <div class="user-details">
                <span style="font-weight: bold;">Admin</span>
                <span id="Logoutbutton">
                    <a asp-controller="Auth" asp-action="Logout" style="font-size: 0.8rem; color: #666;">Logout <i class="bi bi-box-arrow-right"></i></a>
                </span>
            </div>
        </div>

        <ul class="menu">
            <li class="manageOption">
                <a asp-controller="CategoryPage" asp-action="Index">
                    <i class="bi bi-tags"></i>
                    <span>Category Management</span>
                </a>
            </li>
            <hr>
            <li class="manageOption">
                <a asp-controller="ProductPage" asp-action="Index">
                    <i class="bi bi-book"></i>
                    <span>Book Management</span>
                </a>
            </li>
            <hr>
            @* Có thể thêm các menu khác ở đây *@
        </ul>
    </aside>

    <!-- Main Content -->
    <main class="main-content" style="flex: 1; padding: 20px;">
        <div class="container-fluid">
            @RenderBody()
        </div>
    </main>

    <!-- Toast Notification -->
    <partial name="_ToastNotification" />

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
@* <partial name="_PopupNotification" /> *@
@* <script src="~/js/sidebar.js"></script> *@
</html>

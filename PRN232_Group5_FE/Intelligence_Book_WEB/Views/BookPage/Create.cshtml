@model Intelligence_Book_WEB.Models.BookCreateViewModel

@{
    ViewData["Title"] = "Thêm sách mới";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="book-page">
    <div class="d-flex justify-content-between align-items-center mb-4 rounded shadow-sm" style="background-color: #111827; border-left: 5px solid #c5a059; padding: 20px;">
        <h2 class="text-white m-0 fw-bold"><i class="bi bi-journal-plus me-2" style="color: #c5a059;"></i> Thêm sách mới</h2>
    </div>

    <div class="container bg-white p-4 shadow-sm rounded">
        <form asp-controller="BookPage" asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

            <div class="row g-4">
                <div class="col-md-6">
                    <label asp-for="Title" class="form-label fw-bold">Tên sách <span class="text-danger">*</span></label>
                    <input asp-for="Title" class="form-control" placeholder="Tên cuốn sách" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="AuthorName" class="form-label fw-bold">Tên tác giả</label>
                    <input asp-for="AuthorName" class="form-control" placeholder="Tên tác giả" />
                    <span asp-validation-for="AuthorName" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Price" class="form-label fw-bold">Giá bán (VNĐ) <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <input asp-for="Price" class="form-control" type="number" step="1000" min="0" placeholder="0" />
                        <span class="input-group-text bg-light">VNĐ</span>
                    </div>
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="StockQuantity" class="form-label fw-bold">Số lượng tồn kho</label>
                    <input asp-for="StockQuantity" class="form-control" type="number" min="0" placeholder="0" />
                    <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="ISBN" class="form-label fw-bold">Mã ISBN</label>
                    <input asp-for="ISBN" class="form-control" placeholder="Mã số tiêu chuẩn quốc tế (nếu có)" />
                    <span asp-validation-for="ISBN" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Publisher" class="form-label fw-bold">Nhà xuất bản</label>
                    <input asp-for="Publisher" class="form-control" placeholder="Nơi xuất bản" />
                    <span asp-validation-for="Publisher" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="PublishDate" class="form-label fw-bold">Ngày xuất bản</label>
                    <input asp-for="PublishDate" class="form-control" type="date" />
                    <span asp-validation-for="PublishDate" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="CoverImageUrl" class="form-label fw-bold">Ảnh bìa (Bắt buộc) <span class="text-danger">*</span></label>
                    <input asp-for="CoverImageUrl" class="form-control" type="file" accept="image/*" />
                    <span asp-validation-for="CoverImageUrl" class="text-danger small"></span>
                </div>

                <div class="col-md-12">
                    <label class="form-label fw-bold">Chọn danh mục phân loại</label>
                    <div class="border rounded p-3 bg-light shadow-sm" style="max-height: 200px; overflow-y: auto;">
                        @if(Model.AvailableCategories != null && Model.AvailableCategories.Any())
                        {
                            <div class="row w-100 m-0">
                            @foreach (var cat in Model.AvailableCategories)
                            {
                                <div class="col-md-4 col-sm-6 mb-2">
                                    <div class="form-check form-switch custom-switch">
                                        <input class="form-check-input" style="cursor: pointer;" type="checkbox" name="CategoryIds" value="@cat.CategoryId" id="cat_@cat.CategoryId">
                                        <label class="form-check-label ps-1" for="cat_@cat.CategoryId" style="cursor: pointer;">
                                            @cat.CategoryName
                                        </label>
                                    </div>
                                </div>
                            }
                            </div>
                        }
                        else 
                        {
                            <span class="text-muted"><i class="bi bi-info-circle me-1"></i>Chưa có danh mục nào trong hệ thống.</span>
                        }
                    </div>
                    <span asp-validation-for="CategoryIds" class="text-danger small"></span>
                </div>

                <div class="col-md-12">
                    <label asp-for="Description" class="form-label fw-bold">Mô tả nội dung</label>
                    <textarea asp-for="Description" class="form-control" rows="5" placeholder="Nhập tóm tắt hoặc mô tả chi tiết cuốn sách..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>
            </div>

            <div class="mt-5 pt-3 border-top">
                <button type="submit" class="btn text-white px-5 me-2 fw-bold hover-lift" style="background-color: #c5a059;">
                    <i class="bi bi-save me-1"></i> Lưu thông tin
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4 hover-lift">Hủy bỏ</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

@model Intelligence_Book_WEB.Models.BookViewModel

@{
    ViewData["Title"] = "Book Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="book-page">
    <div class="edit-category-header" style="background: linear-gradient(135deg, #F79356 0%, #f57c00 100%); padding: 20px; color: white; margin-bottom: 20px;">
        <h1>Book Details</h1>
    </div>

    <div class="container bg-white p-4 shadow rounded">
        <div class="row">
            <div class="col-md-4 text-center mb-4">
                @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
                {
                    <img src="@Model.CoverImageUrl" alt="Book Cover" class="img-fluid rounded" style="max-height: 400px; box-shadow: 0 4px 8px rgba(0,0,0,0.1);" />
                }
                else
                {
                    <div class="bg-light d-flex align-items-center justify-content-center rounded" style="height: 300px; width: 100%;">
                        <span class="text-muted">No Image Available</span>
                    </div>
                }
            </div>
            <div class="col-md-8">
                <h2 class="text-primary mb-3">@Model.Title</h2>
                
                <table class="table table-bordered">
                    <tbody>
                        <tr>
                            <th style="width: 30%;">Author</th>
                            <td>@(string.IsNullOrEmpty(Model.AuthorName) ? "N/A" : Model.AuthorName)</td>
                        </tr>
                        <tr>
                            <th>Price</th>
                            <td class="text-danger fw-bold">@Model.Price.ToString("C")</td>
                        </tr>
                        <tr>
                            <th>Stock Quantity</th>
                            <td>@Model.StockQuantity</td>
                        </tr>
                        <tr>
                            <th>ISBN</th>
                            <td>@(string.IsNullOrEmpty(Model.ISBN) ? "N/A" : Model.ISBN)</td>
                        </tr>
                        <tr>
                            <th>Publisher</th>
                            <td>@(string.IsNullOrEmpty(Model.Publisher) ? "N/A" : Model.Publisher)</td>
                        </tr>
                        <tr>
                            <th>Publish Date</th>
                            <td>@(Model.PublishDate.HasValue ? Model.PublishDate.Value.ToString("dd/MM/yyyy") : "N/A")</td>
                        </tr>
                        <tr>
                            <th>Categories</th>
                            <td>
                                @if (Model.Categories != null && Model.Categories.Any())
                                {
                                    foreach (var cat in Model.Categories)
                                    {
                                        <span class="badge bg-secondary me-1">@cat.CategoryName</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">No Categories</span>
                                }
                            </td>
                        </tr>
                    </tbody>
                </table>
                
                <div class="mt-4">
                    <h4>Description</h4>
                    <p class="text-muted" style="white-space: pre-wrap;">@(string.IsNullOrEmpty(Model.Description) ? "No description provided." : Model.Description)</p>
                </div>

                <div class="mt-4">
                    <a asp-action="Edit" asp-route-id="@Model.BookId" class="btn btn-warning px-4 me-2">
                        <i class="bi bi-pencil"></i> Edit Book
                    </a>
                    <a asp-action="Index" class="btn btn-secondary px-4">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

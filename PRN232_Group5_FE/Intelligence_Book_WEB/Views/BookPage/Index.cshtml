@model IEnumerable<Intelligence_Book_WEB.Models.BookViewModel>

@{
    ViewData["Title"] = "Book Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="book-page">
    <div class="edit-category-header" style="background: linear-gradient(135deg, #F79356 0%, #f57c00 100%); padding: 20px; color: white;">
        <h1>Book Management</h1>
    </div>

    <div class="p-3">
        <p>
            <a asp-controller="BookPage" asp-action="Create" class="btn btn-primary" style="background-color: #F79356; border: none;">
                <i class="bi bi-plus-circle"></i> Add New Book
            </a>
        </p>

        <table class="table table-hover mt-3">
            <thead style="background-color: #ffe9d0;">
                <tr>
                    <th>Title</th>
                    <th>Author</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var book in Model)
                    {
                        <tr>
                            <td>@book.Title</td>
                            <td>@book.AuthorName</td>
                            <td>@book.Price.ToString("C")</td>
                            <td>@book.StockQuantity</td>
                            <td class="text-center">
                                <a asp-controller="BookPage" asp-action="Details" asp-route-id="@book.BookId" class="btn btn-sm btn-outline-info">
                                    <i class="bi bi-info-circle"></i> Info
                                </a> |
                                <form asp-controller="BookPage" asp-action="Delete" asp-route-id="@book.BookId" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure?');">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center">No books found</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
